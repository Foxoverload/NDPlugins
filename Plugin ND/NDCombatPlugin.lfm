            <label name="lblIni12" align="right" width="50" text="" fontColor="#B0BEC5" fontSize="11" fontStyle="bold" vertTextAlign="center" horzTextAlign="center" margins="{right=6}"/>
        </layout>

        <!-- STATUS -->
        <layout align="top" height="18" margins="{left=6, right=6, top=4}">
            <label name="lblStatus" align="client" text="0 combatentes" fontColor="#546E7A" fontSize="9" horzTextAlign="center" vertTextAlign="center"/>
        </layout>

        <!-- EFEITOS DO TURNO ATUAL -->
        <layout align="top" height="24" margins="{left=6, right=6, top=1}">
            <label name="lblEfeitos" align="client" text="" fontColor="#80DEEA" fontSize="8" horzTextAlign="center" vertTextAlign="center"/>
        </layout>

        <!-- NAVEGACAO -->
        <layout align="top" height="32" margins="{left=6, right=6, top=2}">
            <button name="btnAnterior" align="left" width="120" text="Anterior" fontColor="#B0BEC5" fontSize="10" onClick="turnoAnterior()"/>
            <button name="btnProximo" align="right" width="120" text="Proximo >>" fontColor="#4FC3F7" fontSize="10" onClick="proximoTurno()"/>
        </layout>

        <!-- RODAPE -->
        <layout align="bottom" height="14" margins="{left=6, right=6, bottom=4}">
            <label align="client" text="!removerefeito | !efeitos | !sharingan | !status" fontColor="#37474F" fontSize="7" horzTextAlign="center" vertTextAlign="center"/>
        </layout>
    </layout>
</form>

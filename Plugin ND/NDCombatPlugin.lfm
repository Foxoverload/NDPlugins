<?xml version="1.0" encoding="UTF-8"?>
<form name="frmNDCombatPlugin" formType="tablesDock" dataType="br.com.rrpg.NarutoDestiny_CombatPlugin" title="ND Combate" align="client" theme="dark">
    <script>
        local ndb = require("ndb.lua");

        -- Modo teste
        local MODO_TESTE = false;
        local TESTE_VALOR = 20;

        -- Forward declarations for combat functions (needed by popup)
        local toggleNpcPanel, adicionarJogadores, rolarIniciativas;
        local proximoTurno, limparTracker, removerCombatente;

        -- ========== GUI API EXPLORER ==========
        function explorarGUI()
            if fcext == nil then
                local ok, mod = pcall(require, "fcext");
                if ok and mod then fcext = mod; end;
            end;

            local mesas = Firecast.getMesas();
            local mesa = (mesas ~= nil and #mesas > 0) and mesas[1] or nil;
            local chat = (mesa ~= nil) and mesa.chat or nil;

            -- Helper: deep dump an object's properties
            local function dumpObj(obj, name)
                local result = {};
                -- Direct pairs
                local ok1, _ = pcall(function()
                    for k, v in pairs(obj) do
                        local vstr = tostring(v);
                        if type(v) == "string" then vstr = '"' .. v .. '"'; end;
                        table.insert(result, "  " .. k .. " = " .. type(v) .. " -> " .. vstr);
                    end;
                end);
                -- Try common properties via pcall
                local tryProps = {"name","text","align","width","height","left","top","visible","enabled",
                    "color","fontColor","fontSize","fontStyle","fontFamily","horzTextAlign","vertTextAlign",
                    "parent","margins","padding","hint","cursor","opacity","rotation",
                    "strokeColor","strokeSize","xradius","yradius","hitTest",
                    "field","readOnly","transparent","editable","style","src","checked",
                    "min","max","value","position","interval","items","tabIndex",
                    "scrollBars","wordWrap","backgroundColor","defaultFontColor","defaultFontSize"};
                for _, prop in ipairs(tryProps) do
                    local ok2, val = pcall(function() return obj[prop]; end);
                    if ok2 and val ~= nil then
                        local found = false;
                        for _, r in ipairs(result) do
                            if r:find("  " .. prop .. " =") then found = true; break; end;
                        end;
                        if not found then
                            table.insert(result, "  " .. prop .. " = " .. type(val) .. " -> " .. tostring(val));
                        end;
                    end;
                end;
                return name .. " {\n" .. table.concat(result, "\n") .. "\n}";
            end;

            -- Helper: dump class methods
            local function dumpClass(obj, name)
                local result = {};
                pcall(function()
                    if obj.class then
                        for k, v in pairs(obj.class) do
                            table.insert(result, "  " .. k .. " : " .. type(v));
                        end;
                    end;
                end);
                if #result > 0 then
                    return name .. ".class {\n" .. table.concat(result, "\n") .. "\n}";
                end;
                return "";
            end;

            local allDumps = {};
            table.insert(allDumps, "=== FCEXT GUI API DEEP DUMP ===\n");
            table.insert(allDumps, "Timestamp: " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n");

            -- 1. Dump all GUI functions first
            local guiFuncs = {};
            pcall(function()
                for k, v in pairs(GUI) do
                    table.insert(guiFuncs, "GUI." .. k .. " = " .. type(v));
                end;
            end);
            table.sort(guiFuncs);
            table.insert(allDumps, "=== GUI FUNCTIONS ===\n" .. table.concat(guiFuncs, "\n") .. "\n");

            -- 2. Create test popup as container
            local popup = GUI.newPopupForm();
            popup.title = "GUI API Explorer";
            popup.width = 500;
            popup.height = 600;
            table.insert(allDumps, "\n" .. dumpObj(popup, "PopupForm"));
            table.insert(allDumps, dumpClass(popup, "PopupForm"));

            -- ScrollBox inside popup
            local scroll;
            pcall(function()
                scroll = GUI.newScrollBox();
                scroll.parent = popup;
                scroll.align = "client";
                table.insert(allDumps, "\n" .. dumpObj(scroll, "ScrollBox"));
            end);

            local container = scroll or popup;

            -- 3. Test each control type
            local controls = {
                {"Label", function()
                    local c = GUI.newLabel();
                    c.parent = container; c.align = "top"; c.height = 25;
                    c.text = "Label Test"; c.fontColor = "#4FC3F7"; c.fontSize = 12;
                    return c;
                end},
                {"Button", function()
                    local c = GUI.newButton();
                    c.parent = container; c.align = "top"; c.height = 30;
                    c.text = "Button Test";
                    return c;
                end},
                {"Edit", function()
                    local c = GUI.newEdit();
                    c.parent = container; c.align = "top"; c.height = 25;
                    c.text = "Edit field test";
                    return c;
                end},
                {"Rectangle", function()
                    local c = GUI.newRectangle();
                    c.parent = container; c.align = "top"; c.height = 30;
                    c.color = "#EF4444"; c.strokeColor = "#FFFFFF"; c.strokeSize = 2;
                    c.xradius = 8; c.yradius = 8;
                    return c;
                end},
                {"Layout", function()
                    local c = GUI.newLayout();
                    c.parent = container; c.align = "top"; c.height = 30;
                    return c;
                end},
                {"CheckBox", function()
                    local c = GUI.newCheckBox();
                    c.parent = container; c.align = "top"; c.height = 25;
                    c.text = "Checkbox test";
                    return c;
                end},
                {"ComboBox", function()
                    local c = GUI.newComboBox();
                    c.parent = container; c.align = "top"; c.height = 25;
                    pcall(function() c.items = {"Opção 1", "Opção 2", "Opção 3"}; end);
                    return c;
                end},
                {"ProgressBar", function()
                    local c = GUI.newProgressBar();
                    c.parent = container; c.align = "top"; c.height = 20;
                    pcall(function() c.min = 0; c.max = 100; c.position = 65; end);
                    pcall(function() c.color = "#22C55E"; end);
                    return c;
                end},
                {"HorzLine", function()
                    local c = GUI.newHorzLine();
                    c.parent = container; c.align = "top";
                    return c;
                end},
                {"Image", function()
                    local c = GUI.newImage();
                    c.parent = container; c.align = "top"; c.height = 50;
                    pcall(function() c.style = "autoFit"; end);
                    return c;
                end},
                {"TextEditor", function()
                    local c = GUI.newTextEditor();
                    c.parent = container; c.align = "top"; c.height = 50;
                    pcall(function() c.text = "Multi-line text editor"; end);
                    return c;
                end},
                {"RichEdit", function()
                    local c = GUI.newRichEdit();
                    c.parent = container; c.align = "top"; c.height = 50;
                    return c;
                end},
                {"TabControl", function()
                    local c = GUI.newTabControl();
                    c.parent = container; c.align = "top"; c.height = 80;
                    pcall(function()
                        local t1 = GUI.newTab();
                        t1.parent = c;
                        t1.title = "Tab 1";
                        local t2 = GUI.newTab();
                        t2.parent = c;
                        t2.title = "Tab 2";
                    end);
                    return c;
                end},
                {"Timer", function()
                    local c = GUI.newTimer();
                    pcall(function() c.enabled = false; c.interval = 1000; end);
                    return c;
                end},
                {"ColorComboBox", function()
                    local c = GUI.newColorComboBox();
                    c.parent = container; c.align = "top"; c.height = 25;
                    return c;
                end},
                {"Path", function()
                    local c = GUI.newPath();
                    c.parent = container; c.align = "top"; c.height = 30;
                    return c;
                end},
                {"Frame", function()
                    local c = GUI.newFrame();
                    c.parent = container; c.align = "top"; c.height = 40;
                    return c;
                end},
                {"DataLink", function()
                    local c = GUI.newDataLink();
                    c.parent = container;
                    return c;
                end},
                {"Popup", function()
                    local c = GUI.newPopup();
                    c.width = 100; c.height = 100;
                    return c;
                end},
            };

            local successCount = 0;
            local failCount = 0;
            for _, ctrl in ipairs(controls) do
                local name = ctrl[1];
                local factory = ctrl[2];
                local ok3, obj = pcall(factory);
                if ok3 and obj then
                    successCount = successCount + 1;
                    table.insert(allDumps, "\n" .. dumpObj(obj, name));
                    local classDump = dumpClass(obj, name);
                    if classDump ~= "" then table.insert(allDumps, classDump); end;
                else
                    failCount = failCount + 1;
                    table.insert(allDumps, "\n" .. name .. " -> FAILED: " .. tostring(obj));
                end;
            end;

            -- 4. Try additional GUI functions
            local extraTests = {};
            local extras = {"toast","alert","confirm","inputBox","openInBrowser","openURL",
                "showMessage","dialog","findControlByName","newDataScopeBox",
                "newRadioButton","newRadioGroup","newFlowLayout","newFlowLineBreak",
                "newPanel","newGroupBox","newSplitter","newSplitLayout"};
            for _, fname in ipairs(extras) do
                local exists = false;
                pcall(function() exists = (GUI[fname] ~= nil); end);
                table.insert(extraTests, "GUI." .. fname .. " = " .. (exists and "EXISTS" or "nil"));
            end;
            table.insert(allDumps, "\n=== EXTRA GUI FUNCTIONS ===\n" .. table.concat(extraTests, "\n"));

            -- 5. Write to file
            local fullDump = table.concat(allDumps, "\n");
            if fcext and fcext.log then
                fcext.log("GUI dump: " .. successCount .. " OK, " .. failCount .. " failed");
            end;

            -- Write dump to file via fcext (bypasses sandbox)
            if fcext and fcext.writeFile then
                fcext.writeFile("C:\\Users\\aaron\\AppData\\Local\\Firecast\\fcext_gui_dump.txt", fullDump);
            end;


            -- Show popup with results
            popup:show();

            if chat then
                chat:enviarMensagem("[FCEXT] GUI Explorer: " .. successCount .. " controles OK, " .. failCount .. " falharam");
                chat:enviarMensagem("[FCEXT] Dump salvo em fcext_gui_dump.txt");
            end;
        end;

        -- ========== FICHA DEMO (fcext_ui library test) ==========
        function fichaDemo()
            if fcext == nil then
                local ok, mod = pcall(require, "fcext");
                if ok and mod then fcext = mod; end;
            end;

            local mesas = Firecast.getMesas();
            local mesa = (mesas ~= nil and #mesas > 0) and mesas[1] or nil;
            local chat = (mesa ~= nil) and mesa.chat or nil;

            -- Load UI library
            local uiCode = fcext.readFile("C:\\Users\\aaron\\AppData\\Local\\Firecast\\fcext_ui.lua");
            if not uiCode then
                if chat then chat:enviarMensagem("[FCEXT] ERRO: fcext_ui.lua nao encontrado!"); end;
                return;
            end;

            local ui = load(uiCode)();
            if not ui then
                if chat then chat:enviarMensagem("[FCEXT] ERRO: falha ao carregar fcext_ui.lua!"); end;
                return;
            end;

            -- Create window
            local popup = ui.window({
                title = "Naruto Destiny - Ficha Demo",
                width = 900,
                height = 700,
                show = false,
            });
            local content = popup._content;

            -- Banner
            ui.banner(content, {
                title = "N A R U T O   D E S T I N Y",
                height = 70,
                src = "/images/top_banner.png",
            });

            -- === DADOS PESSOAIS ===
            ui.section(content, {text = "Dados Pessoais"});

            ui.field(content, {label = "Nome", placeholder = "Nome do Personagem"});
            ui.field(content, {label = "Idade", placeholder = "Baseado no Rank"});
            ui.field(content, {label = "Sexo", items = {"Masculino", "Feminino"}});

            -- Grid row (2 columns)
            local gridRow = ui.grid(content, {cols = 2, totalWidth = 850, height = 30, margins = {top = 2}});
            ui.field(gridRow._cols[1], {label = "Altura", labelWidth = 80, placeholder = "x,xxm"});
            ui.field(gridRow._cols[2], {label = "Peso", labelWidth = 80, placeholder = "xx KG"});

            local gridRow2 = ui.grid(content, {cols = 2, totalWidth = 850, height = 30, margins = {top = 2}});
            ui.field(gridRow2._cols[1], {label = "Vila", labelWidth = 80, placeholder = "Vila de nascimento"});
            ui.field(gridRow2._cols[2], {label = "Cla", labelWidth = 80, placeholder = "Cla ninja"});

            ui.separator(content);

            -- === STATUS ===
            ui.section(content, {text = "Status"});

            ui.statBar(content, {
                label = "Pontos de Vida",
                current = 1250,
                max = 2000,
                color = "#EF4444",
                bgColor = "#1A0A10",
            });

            ui.statBar(content, {
                label = "Chakra",
                current = 800,
                max = 1500,
                color = "#818CF8",
                bgColor = "#0A0A1A",
            });

            ui.statBar(content, {
                label = "Estamina",
                current = 600,
                max = 600,
                color = "#FBBF24",
                bgColor = "#1A1A0A",
            });

            ui.separator(content);

            -- === ATRIBUTOS ===
            ui.section(content, {text = "Atributos de Combate"});

            local attrGrid = ui.grid(content, {cols = 2, totalWidth = 850, height = 30, margins = {top = 2}});
            ui.attribute(attrGrid._cols[1], {label = "Taijutsu", labelWidth = 100});
            ui.attribute(attrGrid._cols[2], {label = "Bukijutsu", labelWidth = 100});

            local attrGrid2 = ui.grid(content, {cols = 2, totalWidth = 850, height = 30, margins = {top = 2}});
            ui.attribute(attrGrid2._cols[1], {label = "Ninjutsu", labelWidth = 100});
            ui.attribute(attrGrid2._cols[2], {label = "Genjutsu", labelWidth = 100});

            local attrGrid3 = ui.grid(content, {cols = 2, totalWidth = 850, height = 30, margins = {top = 2}});
            ui.attribute(attrGrid3._cols[1], {label = "Esquiva", labelWidth = 100});
            ui.attribute(attrGrid3._cols[2], {label = "Bloqueio", labelWidth = 100});

            local attrGrid4 = ui.grid(content, {cols = 2, totalWidth = 850, height = 30, margins = {top = 2}});
            ui.attribute(attrGrid4._cols[1], {label = "Reflexo", labelWidth = 100});
            ui.attribute(attrGrid4._cols[2], {label = "Iniciativa", labelWidth = 100});

            ui.separator(content);

            -- === RANK e RECONHECIMENTO ===
            ui.section(content, {text = "Rank e Reconhecimento"});

            -- Rank card
            local rankCard = ui.card(content, {
                title = "Rank Shinobi",
                height = 90,
                headerColor = "#0D3B66",
            });
            local rankBody = rankCard._body;
            ui.label(rankBody, {text = "Jonin", color = "#FBBF24", fontSize = 22, bold = true, textAlign = "center"});
            ui.label(rankBody, {text = "Nivel 35 - 450 XP", color = "#8BA3C4", fontSize = 11, textAlign = "center"});

            -- Badges row
            local badgeRow = GUI.newLayout();
            badgeRow.parent = content;
            badgeRow.align = "top";
            badgeRow.height = 30;
            badgeRow.margins = {top = 6, left = 10};

            ui.badge(badgeRow, {text = "Renome", bgColor = "#B45309", width = 90, margins = {right = 6}});
            ui.badge(badgeRow, {text = "Katon", bgColor = "#EA580C", width = 70, margins = {right = 6}});
            ui.badge(badgeRow, {text = "Suiton", bgColor = "#0284C7", width = 70, margins = {right = 6}});
            ui.badge(badgeRow, {text = "Doton", bgColor = "#A16207", width = 70, margins = {right = 6}});
            ui.badge(badgeRow, {text = "Enton", bgColor = "#7C2D12", width = 70, margins = {right = 6}});

            ui.separator(content);

            -- === APARENCIA ===
            ui.section(content, {text = "Aparencia"});

            local imgRow = GUI.newLayout();
            imgRow.parent = content;
            imgRow.align = "top";
            imgRow.height = 200;
            imgRow.margins = {top = 5, left = 10, right = 10};

            for i = 1, 3 do
                local imgCard = ui.card(imgRow, {
                    align = "left",
                    height = 195,
                    title = "Imagem " .. i,
                    headerHeight = 24,
                    bgColor = "#0E1420",
                    margins = {right = 8},
                });
                imgCard.width = 270;
                ui.image(imgCard._body, {
                    height = 145,
                    editable = true,
                    style = "autoFit",
                });
            end;

            ui.spacer(content, 20);

            -- Show
            popup:show();

            if chat then
                chat:enviarMensagem("[FCEXT] Ficha Demo aberta! UI Library carregada com sucesso.");
            end;
        end;

        -- ========== POPUP COMBAT TRACKER ==========
        local popupRef = nil;

        function atualizarPopup()
            if popupRef == nil then return; end;
            pcall(function() popupRef:close(); end);
            popupRef = nil;
            abrirPopupTracker();
        end;

        function abrirPopupTracker()
            if fcext == nil then
                local ok, mod = pcall(require, "fcext");
                if ok and mod then fcext = mod; end;
            end;

            local cl = combatentes or {};
            local rd = rodadaAtual or 0;
            local tn = turnoAtual or 0;

            local ok1, r1 = pcall(function()
                local popup = GUI.newPopupForm();
                popupRef = popup;
                popup.title = "ND Combat Tracker";
                popup.width = 400;
                popup.height = 520;
                pcall(function() popup:setResizable(true); end);

                -- Colors
                local bgColor = "#2D2D30";
                local headerColor = "#3C3C3C";
                local rowColorA = "#333336";
                local rowColorB = "#2A2A2E";
                local activeRowColor = "#1A3A1A";
                local textColor = "#CCCCCC";
                local dimColor = "#888888";

                -- Background
                local bg = GUI.newRectangle();
                bg.parent = popup;
                bg.align = "client";
                bg.color = bgColor;

                -- ===== HEADER BAR =====
                local headerRow = GUI.newLayout();
                headerRow.parent = popup;
                headerRow.align = "top";
                headerRow.height = 30;

                local headerBgR = GUI.newRectangle();
                headerBgR.parent = headerRow;
                headerBgR.align = "client";
                headerBgR.color = headerColor;

                local btnAdd = GUI.newButton();
                btnAdd.parent = headerRow;
                btnAdd.align = "left";
                btnAdd.width = 28;
                btnAdd.text = "+";
                pcall(function() btnAdd.onClick = function() toggleNpcPanel(); end; end);

                local btnRoll = GUI.newButton();
                btnRoll.parent = headerRow;
                btnRoll.align = "left";
                btnRoll.width = 28;
                btnRoll.text = "R";
                pcall(function() btnRoll.onClick = function() rolarIniciativas(); atualizarPopup(); end; end);

                local btnPlayers = GUI.newButton();
                btnPlayers.parent = headerRow;
                btnPlayers.align = "left";
                btnPlayers.width = 28;
                btnPlayers.text = "A";
                pcall(function() btnPlayers.onClick = function() adicionarJogadores(); atualizarPopup(); end; end);

                local btnClear = GUI.newButton();
                btnClear.parent = headerRow;
                btnClear.align = "right";
                btnClear.width = 45;
                btnClear.text = "Clear";
                pcall(function() btnClear.onClick = function() limparTracker(); atualizarPopup(); end; end);

                -- ===== COLUMN HEADERS =====
                local colRow = GUI.newLayout();
                colRow.parent = popup;
                colRow.align = "top";
                colRow.height = 20;

                local colBg = GUI.newRectangle();
                colBg.parent = colRow;
                colBg.align = "client";
                colBg.color = "#252528";

                local lblChk = GUI.newLabel();
                lblChk.parent = colRow;
                lblChk.align = "left";
                lblChk.width = 50;
                lblChk.text = "  Check";
                lblChk.fontColor = dimColor;
                lblChk.fontSize = 9;

                local lblName = GUI.newLabel();
                lblName.parent = colRow;
                lblName.align = "client";
                lblName.text = "Name";
                lblName.fontColor = dimColor;
                lblName.fontSize = 9;

                local lblInit = GUI.newLabel();
                lblInit.parent = colRow;
                lblInit.align = "right";
                lblInit.width = 35;
                lblInit.text = "Init";
                lblInit.fontColor = dimColor;
                lblInit.fontSize = 9;

                local lblFof = GUI.newLabel();
                lblFof.parent = colRow;
                lblFof.align = "right";
                lblFof.width = 30;
                lblFof.text = "FoF";
                lblFof.fontColor = dimColor;
                lblFof.fontSize = 9;

                -- Separator
                local sep1 = GUI.newHorzLine();
                sep1.parent = popup;
                sep1.align = "top";

                -- ===== COMBATANT ROWS =====
                for i = 1, math.max(#cl, 1) do
                    if i > #cl then break; end;
                    local c = cl[i];
                    local isActive = (i == tn);

                    -- Main row
                    local row = GUI.newLayout();
                    row.parent = popup;
                    row.align = "top";
                    row.height = 26;

                    local rowBg = GUI.newRectangle();
                    rowBg.parent = row;
                    rowBg.align = "client";
                    if isActive then rowBg.color = activeRowColor;
                    elseif i % 2 == 0 then rowBg.color = rowColorB;
                    else rowBg.color = rowColorA; end;

                    -- Arrow
                    local lblArrow = GUI.newLabel();
                    lblArrow.parent = row;
                    lblArrow.align = "left";
                    lblArrow.width = 18;
                    lblArrow.fontColor = "#FFFFFF";
                    lblArrow.fontSize = 12;
                    if isActive then lblArrow.text = ">"; else lblArrow.text = ""; end;

                    -- Check button
                    local btnChk = GUI.newButton();
                    btnChk.parent = row;
                    btnChk.align = "left";
                    btnChk.width = 24;
                    btnChk.text = (c.checked and "[x]" or "[ ]");
                    btnChk.fontSize = 9;

                    -- Name
                    local lblN = GUI.newLabel();
                    lblN.parent = row;
                    lblN.align = "client";
                    lblN.text = " " .. c.nome;
                    lblN.fontColor = textColor;
                    lblN.fontSize = 11;

                    -- Initiative
                    local lblI = GUI.newLabel();
                    lblI.parent = row;
                    lblI.align = "right";
                    lblI.width = 35;
                    lblI.text = tostring(c.ini or "-");
                    lblI.fontColor = "#A0A0A0";
                    lblI.fontSize = 11;

                    -- FoF color indicator
                    local fofRect = GUI.newRectangle();
                    fofRect.parent = row;
                    fofRect.align = "right";
                    fofRect.width = 16;
                    if c.fof == "aliado" then fofRect.color = "#22C55E";
                    elseif c.fof == "inimigo" then fofRect.color = "#EF4444";
                    elseif c.fof == "neutro" then fofRect.color = "#FBBF24";
                    else fofRect.color = "#666666"; end;

                    -- Remove button
                    local btnRem = GUI.newButton();
                    btnRem.parent = row;
                    btnRem.align = "right";
                    btnRem.width = 22;
                    btnRem.text = "X";
                    btnRem.fontSize = 10;
                    local idx = i;
                    pcall(function() btnRem.onClick = function() removerCombatente(idx); atualizarPopup(); end; end);

                    -- Effect row (if has effects)
                    if c.efeitos and #c.efeitos > 0 then
                        local efRow = GUI.newLayout();
                        efRow.parent = popup;
                        efRow.align = "top";
                        efRow.height = 16;

                        local efBg = GUI.newRectangle();
                        efBg.parent = efRow;
                        efBg.align = "client";
                        efBg.color = "#0D1117";

                        local efTexts = {};
                        for _, ef in ipairs(c.efeitos) do
                            local t = ef.nome;
                            if ef.duracao and ef.duracao > 0 then t = t .. "(" .. ef.duracao .. "rd)"; end;
                            table.insert(efTexts, t);
                        end;

                        local lblEf = GUI.newLabel();
                        lblEf.parent = efRow;
                        lblEf.align = "client";
                        lblEf.text = "     " .. table.concat(efTexts, " | ");
                        lblEf.fontColor = "#80DEEA";
                        lblEf.fontSize = 9;
                    end;
                end;

                if #cl == 0 then
                    local emptyRow = GUI.newLayout();
                    emptyRow.parent = popup;
                    emptyRow.align = "top";
                    emptyRow.height = 60;

                    local emptyBg = GUI.newRectangle();
                    emptyBg.parent = emptyRow;
                    emptyBg.align = "client";
                    emptyBg.color = rowColorA;

                    local lblEmpty = GUI.newLabel();
                    lblEmpty.parent = emptyRow;
                    lblEmpty.align = "client";
                    lblEmpty.text = "   Sem combatentes";
                    lblEmpty.fontColor = dimColor;
                    lblEmpty.fontSize = 11;
                end;

                -- ===== FOOTER =====
                local footSep = GUI.newHorzLine();
                footSep.parent = popup;
                footSep.align = "bottom";

                local footer = GUI.newLayout();
                footer.parent = popup;
                footer.align = "bottom";
                footer.height = 34;

                local footBg = GUI.newRectangle();
                footBg.parent = footer;
                footBg.align = "client";
                footBg.color = headerColor;

                local btnNextTurn = GUI.newButton();
                btnNextTurn.parent = footer;
                btnNextTurn.align = "left";
                btnNextTurn.width = 85;
                btnNextTurn.text = "Next turn";
                pcall(function() btnNextTurn.onClick = function() proximoTurno(); atualizarPopup(); end; end);

                local lblRound = GUI.newLabel();
                lblRound.parent = footer;
                lblRound.align = "right";
                lblRound.width = 80;
                lblRound.text = "Round: " .. rd;
                lblRound.fontColor = textColor;
                lblRound.fontSize = 11;

                popup:show();
                return "TRACKER ABERTO!";
            end);

            local mesas = Firecast.getMesas();
            local mesa = (mesas ~= nil and #mesas > 0) and mesas[1] or nil;
            local chat = (mesa ~= nil) and mesa.chat or nil;
            if chat then chat:enviarMensagem("[FCEXT] " .. (ok1 and r1 or ("ERR: " .. tostring(r1)))); end;
        end;

        function testarFcext()
            abrirPopupTracker();
        end;

        function fecharOverlay()
            if fcext == nil then
                local ok, mod = pcall(require, "fcext");
                if ok and mod then fcext = mod; end;
            end;
            if fcext and fcext.overlayClose then
                fcext.overlayClose();
            end;
        end;
        -- ========== COMANDOS DE COMBATE ==========
        local COMANDOS_COMBATE = {
            ["taijutsu"]    = {campo = "taijutsu",       nome = "Taijutsu",        fisico = true},
            ["bukijutsu"]   = {campo = "bukijutsu",      nome = "Bukijutsu",       fisico = true},
            ["ninjutsu"]    = {campo = "ninjutsu",        nome = "Ninjutsu",        fisico = false},
            ["genjutsu"]    = {campo = "genjutsu",        nome = "Genjutsu",        fisico = false},
            ["kai"]         = {campo = "genjutsu_kai",    nome = "Genjutsu Kai",    fisico = false},
            ["fuinjutsu"]   = {campo = "fuinjutsu",       nome = "Fuinjutsu",       fisico = false},
            ["arremesso"]   = {campo = "arremesso",       nome = "Arremesso",       fisico = false},
            ["esquiva"]     = {campo = "esquiva",         nome = "Esquiva",         fisico = false},
            ["bloqfisico"]  = {campo = "bloqueio_fisico", nome = "Bloqueio Fisico", fisico = false},
            ["bloqchakra"]  = {campo = "bloqueio_chakra", nome = "Bloqueio Chakra", fisico = false},
            ["reflexo"]     = {campo = "reflexo",         nome = "Reflexo",         fisico = false},
            ["iniciativa"]  = {campo = "iniciativa",      nome = "Iniciativa",      fisico = false},
            ["tai-buki"]    = {campo = "tai_bukijutsu",   nome = "Tai-Bukijutsu",   fisico = true},
            ["nin-tai"]     = {campo = "nin_taijutsu",    nome = "Nin-Taijutsu",    fisico = false},
            ["hiraishin"]   = {campo = "hiraishin",       nome = "Hiraishin",       fisico = false},
            ["mover"]       = {campo = "movimentacao",    nome = "Movimentacao",    fisico = false},
        };

        -- ========== FUNCOES AUXILIARES ==========
        local function buscarFichaEExecutar(mesa, chat, callback)
            if mesa == nil then
                if chat ~= nil then chat:enviarMensagem("Erro: mesa nao encontrada."); end;
                return;
            end;
            local meuJogador = mesa.meuJogador;
            if meuJogador == nil then
                if chat ~= nil then chat:enviarMensagem("Erro: jogador nao encontrado."); end;
                return;
            end;
            local codPersonagem = meuJogador.personagemPrincipal;
            if codPersonagem ~= nil and codPersonagem ~= 0 then
                local bibItem = mesa:findBibliotecaItem(codPersonagem);
                if bibItem ~= nil then
                    bibItem:loadSheetNDB(function(sheetNode)
                        if sheetNode ~= nil then callback(sheetNode);
                        else chat:enviarMensagem("Erro ao carregar ficha."); end;
                    end);
                    return;
                end;
            end;
            local bib = mesa.biblioteca;
            if bib ~= nil then
                local filhos = bib.filhos;
                if filhos ~= nil then
                    for i = 1, #filhos, 1 do
                        local item = filhos[i];
                        if item ~= nil and item.tipo == "personagem" and item.loginDono == meuJogador.login then
                            item:loadSheetNDB(function(sheetNode)
                                if sheetNode ~= nil then callback(sheetNode);
                                else chat:enviarMensagem("Erro ao carregar ficha."); end;
                            end);
                            return;
                        end;
                    end;
                end;
            end;
            chat:enviarMensagem("Nenhuma ficha encontrada.");
        end;

        local function verificarZeroStatus(sheetNode, chat, nome)
            if sheetNode == nil or chat == nil then return; end;
            local pvAt = tonumber(sheetNode.pv_atual) or 0;
            local chkAt = tonumber(sheetNode.pchakra_atual) or 0;
            local estAt = tonumber(sheetNode.pestamina_atual) or 0;
            if pvAt &lt;= 0 then chat:enviarMensagem("DERROTADO! " .. nome .. " PV zerado (" .. pvAt .. ")."); end;
            if chkAt &lt;= 0 and estAt &lt;= 0 then
                chat:enviarMensagem("ALERTA: " .. nome .. " Chakra E Estamina zerados! -8 em todas as acoes.");
            elseif chkAt &lt;= 0 then
                chat:enviarMensagem("ALERTA: " .. nome .. " Chakra zerado! -4 em todas as acoes.");
            elseif estAt &lt;= 0 then
                chat:enviarMensagem("ALERTA: " .. nome .. " Estamina zerada! -4 em todas as acoes.");
            end;
        end;

        -- ========== TRACKER DE INICIATIVA ==========
        local combatentes = {};
        local turnoAtual = 0;
        local rodadaAtual = 0;
        local MAX_LINHAS = 10;

        -- Forward declarations (definidas mais abaixo)
        local buscarCombatente;
        local calcularBonusEfeitos;
        local calcularBonusTotal;
        local adicionarEfeitoAoCombatente;
        local processarEfeitos;

        local function ordenarCombatentes()
            table.sort(combatentes, function(a, b) return (a.ini or 0) > (b.ini or 0); end);
        end;

        local function renderizarTracker()
            if rodadaAtual == 0 then ordenarCombatentes(); end;
            for i = 1, MAX_LINHAS do
                local lblArrow = self["lblArrow" .. i];
                local btnChk = self["btnChk" .. i];
                local lblNome = self["lblNome" .. i];
                local lblIni = self["lblIni" .. i];
                local btnFof = self["btnFof" .. i];
                local btnX = self["btnX" .. i];
                local lblEfRow = self["lblEfRow" .. i];
                local lblDur = self["lblDur" .. i];
                local rowMain = self["rowMain" .. i];
                local rowEf = self["rowEf" .. i];
                if lblNome ~= nil then
                    if i &lt;= #combatentes then
                        local co = combatentes[i];
                        if rowMain ~= nil then rowMain.visible = true; end;
                        if rowEf ~= nil then rowEf.visible = true; end;
                        -- Arrow
                        if lblArrow ~= nil then
                            if i == turnoAtual then lblArrow.text = "&gt;"; lblArrow.fontColor = "#FFFFFF";
                            else lblArrow.text = ""; end;
                        end;
                        -- Checkbox
                        if btnChk ~= nil then
                            if co.checked == false then btnChk.text = "";
                            else btnChk.text = "X"; end;
                        end;
                        -- Nome
                        lblNome.text = co.nome or "?";
                        -- Ini
                        if lblIni ~= nil then lblIni.text = tostring(co.ini or 0); end;
                        -- FoF color
                        local fof = co.fof or "aliado";
                        local fofC = "#22C55E";
                        if fof == "neutro" then fofC = "#EAB308";
                        elseif fof == "inimigo" then fofC = "#EF4444"; end;
                        if btnFof ~= nil then btnFof.fontColor = fofC; btnFof.text = "@"; end;
                        -- Font colors
                        if i == turnoAtual then
                            lblNome.fontColor = "#FFFFFF";
                            if lblIni ~= nil then lblIni.fontColor = "#FFFFFF"; end;
                        else
                            lblNome.fontColor = "#C0C0C0";
                            if lblIni ~= nil then lblIni.fontColor = "#A0A0A0"; end;
                        end;
                        -- Effects sub-line
                        if lblEfRow ~= nil then
                            if co.efeitos ~= nil and #co.efeitos &gt; 0 then
                                local nomes = {};
                                local durTxt = "";
                                for ei = 1, #co.efeitos do
                                    table.insert(nomes, co.efeitos[ei].nome);
                                    local d = co.efeitos[ei].duracao or 0;
                                    if d &gt; 0 then durTxt = durTxt .. "[" .. d .. "] ";
                                    else durTxt = durTxt .. "[~] "; end;
                                end;
                                lblEfRow.text = table.concat(nomes, " | ");
                                if lblDur ~= nil then lblDur.text = durTxt; end;
                            else
                                lblEfRow.text = "";
                                if lblDur ~= nil then lblDur.text = ""; end;
                            end;
                        end;
                    else
                        if rowMain ~= nil then rowMain.visible = false; end;
                        if rowEf ~= nil then rowEf.visible = false; end;
                    end;
                end;
            end;
            if self.lblStatus ~= nil then
                local statusTxt = #combatentes .. " combatentes";
                if rodadaAtual &gt; 0 then
                    statusTxt = "Rodada " .. rodadaAtual;
                    if turnoAtual &gt; 0 and turnoAtual &lt;= #combatentes then
                        statusTxt = statusTxt .. " | Turno: " .. combatentes[turnoAtual].nome;
                    end;
                end;
                self.lblStatus.text = statusTxt;
            end;
            if self.lblRoundNum ~= nil then
                self.lblRoundNum.text = tostring(rodadaAtual);
            end;
        end;

        local function toggleCheck(idx)
            if idx &gt; #combatentes then return; end;
            combatentes[idx].checked = not combatentes[idx].checked;
            renderizarTracker();
        end;

        local function ciclarFoF(idx)
            if idx &gt; #combatentes then return; end;
            local co = combatentes[idx];
            if co.fof == "aliado" then co.fof = "neutro";
            elseif co.fof == "neutro" then co.fof = "inimigo";
            else co.fof = "aliado"; end;
            renderizarTracker();
        end;

        local function removerCombatente(idx)
            if idx &gt; #combatentes then return; end;
            table.remove(combatentes, idx);
            if turnoAtual &gt; #combatentes then turnoAtual = #combatentes; end;
            renderizarTracker();
        end;

        toggleNpcPanel = function()
            if self.pnlNpcInput ~= nil then
                self.pnlNpcInput.visible = not self.pnlNpcInput.visible;
            end;
        end;

        adicionarJogadores = function()
            local mesas = Firecast.getMesas();
            if mesas == nil or #mesas == 0 then return; end;
            local mesa = mesas[1];
            local jogadores = mesa.jogadores;
            if jogadores == nil then return; end;

            for i = 1, #jogadores do
                local jog = jogadores[i];
                if jog ~= nil and not jog.isMestre then
                    local nick = jog.nick or jog.login or ("Jogador " .. i);
                    -- Remover tags de formatacao [...] do nick manualmente
                    local limpo = "";
                    local dentro = false;
                    for ci = 1, string.len(nick) do
                        local ch = string.sub(nick, ci, ci);
                        if ch == "[" then dentro = true;
                        elseif ch == "]" then dentro = false;
                        elseif not dentro then limpo = limpo .. ch;
                        end;
                    end;
                    nick = limpo;
                    if nick == "" then nick = jog.login or ("Jogador " .. i); end;
                    local login = jog.login or "";
                    -- Verificar se ja existe no tracker
                    local jaExiste = false;
                    for j = 1, #combatentes do
                        if combatentes[j].login == login then
                            jaExiste = true;
                            break;
                        end;
                    end;
                    if not jaExiste then
                        -- Tentar buscar iniciativa da ficha
                        local codPersonagem = jog.personagemPrincipal;
                        if codPersonagem ~= nil and codPersonagem ~= 0 then
                            local bibItem = mesa:findBibliotecaItem(codPersonagem);
                            if bibItem ~= nil then
                                bibItem:loadSheetNDB(function(sheetNode)
                                    local ini = 0;
                                    local nomeSheet = nick;
                                    if sheetNode ~= nil then
                                        ini = tonumber(sheetNode.iniciativa) or 0;
                                        local sn = sheetNode.nome;
                                        if sn ~= nil and sn ~= "" then nomeSheet = sn; end;
                                    end;
                                    table.insert(combatentes, {nome = nomeSheet, ini = ini, tipo = "jogador", login = login, baseIni = ini, bibCode = codPersonagem, fof = "aliado", checked = true});
                                    renderizarTracker();
                                end);
                            else
                                table.insert(combatentes, {nome = nick, ini = 0, tipo = "jogador", login = login, baseIni = 0, bibCode = nil, fof = "aliado", checked = true});
                            end;
                        else
                            table.insert(combatentes, {nome = nick, ini = 0, tipo = "jogador", login = login, baseIni = 0, bibCode = nil, fof = "aliado", checked = true});
                        end;
                    end;
                end;
            end;
            renderizarTracker();
        end;

        local function adicionarNPC()
            local nomeEdit = self.edtNpcNome;
            local iniEdit = self.edtNpcIni;
            if nomeEdit == nil or iniEdit == nil then return; end;
            local nome = nomeEdit.text or "";
            local ini = tonumber(iniEdit.text) or 0;
            if nome == "" then return; end;
            table.insert(combatentes, {nome = nome, ini = ini, tipo = "npc", bibCode = nil, baseIni = ini, fof = "inimigo", checked = true});
            nomeEdit.text = "";
            iniEdit.text = "";
            renderizarTracker();
        end;

        rolarIniciativas = function()
            local mesas = Firecast.getMesas();
            local mesa = (mesas ~= nil and #mesas > 0) and mesas[1] or nil;
            local chat = (mesa ~= nil) and mesa.chat or nil;

            for i = 1, #combatentes do
                local c = combatentes[i];
                local baseIni = c.baseIni or 0;
                if MODO_TESTE then
                    c.ini = TESTE_VALOR + baseIni;
                    if chat ~= nil then
                        chat:enviarMensagem("Iniciativa: " .. c.nome .. " [TESTE] 1d20+" .. baseIni .. " = " .. c.ini);
                    end;
                else
                    local rol = Firecast.interpretarRolagem("1d20 + " .. baseIni);
                    rol:rolarLocalmente();
                    c.ini = rol.resultado or baseIni;
                    local d20 = c.ini - baseIni;
                    if chat ~= nil then
                        chat:enviarMensagem(c.nome .. " rolou 1d20+" .. baseIni .. " = " .. c.ini .. " {[" .. d20 .. "]+" .. baseIni .. "}");
                    end;
                end;
            end;
            -- Ordenar por resultado de iniciativa (maior primeiro)
            table.sort(combatentes, function(a, b) return (a.ini or 0) > (b.ini or 0); end);
            turnoAtual = 1;
            rodadaAtual = 1;
            if chat ~= nil then
                chat:enviarMensagem("--- Ordem de Iniciativa ---");
                for i = 1, #combatentes do
                    chat:enviarMensagem(i .. ". " .. combatentes[i].nome .. " (" .. combatentes[i].ini .. ")");
                end;
            end;
            renderizarTracker();
        end;

        proximoTurno = function()
            if #combatentes == 0 then return; end;
            turnoAtual = turnoAtual + 1;
            local novaRodada = false;
            if turnoAtual > #combatentes then
                turnoAtual = 1;
                rodadaAtual = rodadaAtual + 1;
                novaRodada = true;
            end;

            local mesas = Firecast.getMesas();
            local mesa = (mesas ~= nil and #mesas > 0) and mesas[1] or nil;
            local chat = (mesa ~= nil) and mesa.chat or nil;
            if chat ~= nil then
                if novaRodada then
                    chat:enviarMensagem("========== RODADA " .. rodadaAtual .. " ==========");
                    processarEfeitos(chat);
                end;
                if turnoAtual &lt;= #combatentes then
                    local efBonus = calcularBonusTotal(combatentes[turnoAtual]);
                    local efTxt = "";
                    if efBonus ~= 0 then
                        efTxt = " | Efeitos: " .. (efBonus > 0 and "+" or "") .. efBonus .. " atb";
                    end;
                    chat:enviarMensagem(">> Turno de: " .. combatentes[turnoAtual].nome .. " (Ini: " .. combatentes[turnoAtual].ini .. ")" .. efTxt);
                end;
            end;
            renderizarTracker();
        end;

        local function turnoAnterior()
            if #combatentes == 0 then return; end;
            turnoAtual = turnoAtual - 1;
            if turnoAtual &lt; 1 then turnoAtual = #combatentes; end;
            renderizarTracker();
        end;

        limparTracker = function()
            combatentes = {};
            turnoAtual = 0;
            rodadaAtual = 0;
            renderizarTracker();
        end;

        removerCombatente = function(indice)
            if indice &lt;= #combatentes then
                table.remove(combatentes, indice);
                if turnoAtual > #combatentes then turnoAtual = #combatentes; end;
                renderizarTracker();
            end;
        end;

        -- ========== SISTEMA DE EFEITOS ==========
        -- Atributos por tipo de efeito
        local SHARINGAN_ATBS = {"taijutsu", "bukijutsu", "ninjutsu", "nin_taijutsu", "hiraishin", "genjutsu", "genjutsu_kai", "arremesso", "esquiva", "movimentacao", "bloqueio_fisico", "bloqueio_chakra"};
        local ELETROCUTAR_ATBS = {"taijutsu", "bukijutsu", "arremesso", "esquiva", "bloqueio_fisico"};
        local CONGELA_ATBS = {"taijutsu", "bukijutsu", "arremesso", "esquiva", "bloqueio_fisico", "reflexo"};
        local DEFESA_ATBS = {"esquiva", "bloqueio_fisico", "bloqueio_chakra", "reflexo"};
        local GENJUTSU_ATBS = {"esquiva", "bloqueio_fisico", "bloqueio_chakra", "genjutsu_kai", "reflexo"};

        -- Tabela de efeitos pre-definidos
        local EFEITOS_CMD = {
            -- === PERMANENTES (dano) ===
            ["corrosao"]     = {nome = "Corrosao",         tipo = "dano",    atbs = nil,            uso = "!corrosao [comb] [dano/rd]"},
            ["corrosaoac"]   = {nome = "Corrosao-Acido",   tipo = "dano",    atbs = nil,            uso = "!corrosaoac [comb] [dano/rd]"},
            ["queimadura"]   = {nome = "Queimadura",       tipo = "dano",    atbs = nil,            uso = "!queimadura [comb] [dano/rd]"},
            ["queimalava"]   = {nome = "Queimadura-Lava",  tipo = "danomult",mult = 1.4, atbs = nil,uso = "!queimalava [comb] [dano_base]"},
            ["amaterasu"]    = {nome = "Amaterasu",        tipo = "danomult",mult = 1.4, atbs = nil,uso = "!amaterasu [comb] [dano_base]"},
            ["sangramento"]  = {nome = "Sangramento",     tipo = "dano",    atbs = nil,            uso = "!sangramento [comb] [dano/rd]"},
            -- === PERMANENTES (redutor) ===
            ["congelamento"] = {nome = "Congelamento",     tipo = "redutor", atbs = CONGELA_ATBS,   uso = "!congelamento [comb] [penalidade]"},
            ["cristalizacao"]= {nome = "Cristalizacao",    tipo = "redutor", atbs = CONGELA_ATBS,   uso = "!cristalizacao [comb] [penalidade]"},
            ["desidratacao"] = {nome = "Desidratacao",     tipo = "redutor", atbs = nil,            uso = "!desidratacao [comb] [penalidade]"},
            ["tenketsu"]     = {nome = "Tenketsu-Fechado", tipo = "redutor", atbs = nil,            uso = "!tenketsu [comb] [penalidade]"},
            ["magnetizacao"] = {nome = "Magnetizacao",     tipo = "redutor", atbs = nil,            uso = "!magnetizacao [comb] [penalidade]"},
            -- === PERMANENTES (hibrido) ===
            ["envenenamento"]= {nome = "Envenenamento",    tipo = "hibrido",atbs = nil,             uso = "!envenenamento [comb] [penalidade] [dano/rd]"},
            ["esmagamento"]  = {nome = "Esmagamento",     tipo = "hibrido",atbs = nil,             uso = "!esmagamento [comb] [penalidade] [dano/rd]"},
            ["perfuracao"]   = {nome = "Perfuracao",       tipo = "hibrido",atbs = nil,             uso = "!perfuracao [comb] [penalidade] [dano/rd]"},
            -- === PERMANENTES (especiais) ===
            ["desintegracao"]= {nome = "Desintegracao",    tipo = "info",   atbs = nil,             uso = "!desintegracao [comb] [% PV]"},
            ["explosao"]     = {nome = "Explosao",         tipo = "info",   atbs = nil,             uso = "!explosao [comb] [dano_extra]"},
            ["bakuton"]      = {nome = "Explosao-Bakuton", tipo = "bakuton",atbs = DEFESA_ATBS,     uso = "!bakuton [comb] [penalidade]"},
            -- === TEMPORARIOS ===
            ["atordoamento"] = {nome = "Atordoamento",     tipo = "redutortmp", atbs = CONGELA_ATBS,uso = "!atordoamento [comb] [penalidade] [rodadas]"},
            ["eletrocutar"]  = {nome = "Eletrocussao",     tipo = "eletro", atbs = ELETROCUTAR_ATBS,uso = "!eletrocutar [comb] [penalidade] [dano/rd] [rodadas]"},
            ["eletroranton"] = {nome = "Eletrocussao-Ranton",tipo = "eletro",atbs = ELETROCUTAR_ATBS,uso = "!eletroranton [comb] [penalidade] [dano/rd] [rodadas]"},
            ["genjutsuef"]   = {nome = "Genjutsu",         tipo = "redutortmp", atbs = GENJUTSU_ATBS,uso = "!genjutsuef [comb] [penalidade] [rodadas]"},
            ["percavisao"]   = {nome = "Perca-de-Visao",   tipo = "redutortmp", atbs = nil,         uso = "!percavisao [comb] [penalidade] [rodadas]"},
            ["afogamento"]   = {nome = "Afogamento",       tipo = "afoga",  atbs = nil,             uso = "!afogamento [comb] [dano/rd] [estamina/rd] [rodadas]"},
            ["sufocamento"]  = {nome = "Sufocamento",      tipo = "afoga",  atbs = nil,             uso = "!sufocamento [comb] [dano/rd] [estamina/rd] [rodadas]"},
            ["alterarchk"]   = {nome = "Alterar-Ctrl-CHK", tipo = "infotmp",atbs = nil,             uso = "!alterarchk [comb] [+chakra] [tecnicas]"},
            ["exaustao"]     = {nome = "Exaustao",         tipo = "exaustao",atbs = CONGELA_ATBS,   uso = "!exaustao [comb] [penalidade] [+estamina] [tecnicas]"},
            ["exaustaoilus"] = {nome = "Exaustao-Ilusoria",tipo = "infotmp",atbs = nil,             uso = "!exaustaoilus [comb] [+estamina] [tecnicas]"},
            ["reducaores"]   = {nome = "Reducao-Resistencia",tipo = "infotmp",atbs = nil,           uso = "!reducaores [comb] [+dano_recebido] [rodadas]"},
        };

        buscarCombatente = function(nomeParcial)
            if nomeParcial == nil or nomeParcial == "" then return nil; end;
            nomeParcial = string.lower(nomeParcial);
            for i = 1, #combatentes do
                if string.lower(combatentes[i].nome) == nomeParcial then return combatentes[i]; end;
            end;
            for i = 1, #combatentes do
                if string.find(string.lower(combatentes[i].nome), nomeParcial, 1, true) then return combatentes[i]; end;
            end;
            return nil;
        end;

        calcularBonusEfeitos = function(combatente, campo)
            local bonus = 0;
            if combatente == nil or combatente.efeitos == nil then return 0; end;
            for i = 1, #combatente.efeitos do
                local ef = combatente.efeitos[i];
                if ef.atributos ~= nil then
                    -- Bonus por atributo especifico
                    for j = 1, #ef.atributos do
                        if ef.atributos[j] == campo then
                            bonus = bonus + (ef.bonusAtb or 0);
                            break;
                        end;
                    end;
                else
                    -- Bonus global (todos os atributos)
                    bonus = bonus + (ef.bonusAtb or 0);
                end;
            end;
            return bonus;
        end;

        calcularBonusTotal = function(combatente)
            local bonus = 0;
            if combatente == nil or combatente.efeitos == nil then return 0; end;
            for i = 1, #combatente.efeitos do
                bonus = bonus + (combatente.efeitos[i].bonusAtb or 0);
            end;
            return bonus;
        end;

        adicionarEfeitoAoCombatente = function(comb, ef, chat)
            if comb.efeitos == nil then comb.efeitos = {}; end;
            if #comb.efeitos &gt;= 2 then
                chat:enviarMensagem("[AVISO] " .. comb.nome .. " limite de efeitos.");
                table.remove(comb.efeitos, 1);
            end;
            table.insert(comb.efeitos, ef);
            local durTxt = (ef.duracao ~= nil and ef.duracao > 0) and (ef.duracao .. " rodadas") or "permanente";
            local bonTxt = (ef.bonusAtb ~= nil and ef.bonusAtb ~= 0) and ((ef.bonusAtb > 0 and "+" or "") .. ef.bonusAtb .. " atb") or "";
            local dmgTxt = (ef.danoRodada ~= nil and ef.danoRodada > 0) and (ef.danoRodada .. " dano/rd") or "";
            local chkTxt = (ef.custoChakraRd ~= nil and ef.custoChakraRd > 0) and (ef.custoChakraRd .. " chk/rd") or "";
            chat:enviarMensagem("[EFEITO] " .. comb.nome .. " recebe " .. ef.nome .. ": " .. bonTxt .. " " .. dmgTxt .. " " .. chkTxt .. " (" .. durTxt .. ")");
            renderizarTracker();
        end;

        processarEfeitos = function(chat)
            for i = 1, #combatentes do
                local c = combatentes[i];
                if c.efeitos ~= nil and #c.efeitos > 0 then
                    local j = 1;
                    while j &lt;= #c.efeitos do
                        local ef = c.efeitos[j];
                        -- Identificador para comandos de barra
                        local barId = c.login or c.nome;
                        -- Aplicar dano
                        if ef.danoRodada ~= nil and ef.danoRodada > 0 then
                            chat:enviarMensagem("[EFEITO] " .. c.nome .. ": " .. ef.nome .. " causa " .. ef.danoRodada .. " de dano.");
                            if c.tipo == "jogador" then
                                chat:enviarMensagem("/vida " .. barId .. " -" .. ef.danoRodada);
                            end;
                        end;
                        -- Aplicar perda de estamina (afogamento/sufocamento)
                        if ef.estaminaRodada ~= nil and ef.estaminaRodada > 0 then
                            chat:enviarMensagem("[EFEITO] " .. c.nome .. ": " .. ef.nome .. " drena " .. ef.estaminaRodada .. " de estamina.");
                            if c.tipo == "jogador" then
                                chat:enviarMensagem("/estamina " .. barId .. " -" .. ef.estaminaRodada);
                            end;
                        end;
                        -- Custo de chakra para manter
                        if ef.custoChakraRd ~= nil and ef.custoChakraRd > 0 then
                            chat:enviarMensagem("[EFEITO] " .. c.nome .. ": " .. ef.nome .. " consome " .. ef.custoChakraRd .. " de chakra.");
                            if c.tipo == "jogador" then
                                chat:enviarMensagem("/chakra " .. barId .. " -" .. ef.custoChakraRd);
                            end;
                        end;
                        -- Decrementar duracao
                        if ef.duracao ~= nil and ef.duracao > 0 then
                            ef.duracao = ef.duracao - 1;
                            if ef.duracao &lt;= 0 then
                                chat:enviarMensagem("[EFEITO] " .. c.nome .. ": " .. ef.nome .. " EXPIROU!");
                                table.remove(c.efeitos, j);
                            else
                                chat:enviarMensagem("[EFEITO] " .. c.nome .. ": " .. ef.nome .. " (" .. ef.duracao .. " rodadas restantes)");
                                j = j + 1;
                            end;
                        else
                            j = j + 1;
                        end;
                    end;
                end;
            end;
            renderizarTracker();
        end;

        -- ========== HANDLER DE CHAT ==========
        Firecast.messaging.listen("HandleChatTextInput",
            function(message)
                if message.O_texto_foi_processado then return; end;
                local texto = message.texto or "";
                local cmd = string.match(texto, "^!(%S+)");
                if cmd == nil then return; end;
                cmd = string.lower(cmd);
                local ehNosso = (cmd == "status" or cmd == "sorte" or cmd == "testar" or cmd == "efeito" or cmd == "efeitos" or cmd == "removerefeito" or cmd == "sharingan" or EFEITOS_CMD[cmd] ~= nil or COMANDOS_COMBATE[cmd] ~= nil);
                if not ehNosso then return; end;
                local mesa = message.mesa or message.room;
                local chat = message.chat;
                if mesa == nil then
                    local mesas = Firecast.getMesas();
                    if mesas ~= nil and #mesas > 0 then mesa = mesas[1]; end;
                end;
                if chat == nil and mesa ~= nil then chat = mesa.chat; end;
                if mesa == nil or chat == nil then return; end;

                if cmd == "testar" then
                    local param = string.match(texto, "^!testar%s+(%S+)");
                    if param ~= nil then param = string.lower(param); end;
                    if param == "off" then
                        MODO_TESTE = false;
                        chat:enviarMensagem("[TESTE] Modo teste DESLIGADO.");
                    else
                        local val = tonumber(param);
                        if val ~= nil then
                            MODO_TESTE = true; TESTE_VALOR = val;
                            chat:enviarMensagem("[TESTE] Modo teste LIGADO. d20 fixo = " .. val);
                        else
                            chat:enviarMensagem("[TESTE] " .. (MODO_TESTE and ("Ativo: d20=" .. TESTE_VALOR) or "Inativo") .. ". Use !testar N ou !testar off");
                        end;
                    end;
                    message.O_texto_foi_processado = true; return true;
                end;

                if cmd == "status" then
                    buscarFichaEExecutar(mesa, chat, function(sheetNode)
                        local nome = tostring(sheetNode.nome) or "?";
                        local msg = "Status de " .. nome .. " | PV: " .. (sheetNode.pv_atual or "?") .. "/" .. (sheetNode.pv or "?");
                        msg = msg .. " | Chakra: " .. (sheetNode.pchakra_atual or "?") .. "/" .. (sheetNode.pchakra or "?");
                        msg = msg .. " | Estamina: " .. (sheetNode.pestamina_atual or "?") .. "/" .. (sheetNode.pestamina or "?");
                        chat:enviarMensagem(msg);
                    end);
                    message.O_texto_foi_processado = true; return true;
                end;

                if cmd == "sorte" then
                    buscarFichaEExecutar(mesa, chat, function(sheetNode)
                        local sorteAt = tonumber(sheetNode.sorte) or 0;
                        local nome = tostring(sheetNode.nome) or "?";
                        if sorteAt > 0 then
                            sheetNode.sorte = tostring(sorteAt - 1);
                            chat:enviarMensagem("[SORTE] " .. nome .. " usa 1 ponto! Valor = 15. (Restante: " .. (sorteAt - 1) .. ")");
                        else
                            chat:enviarMensagem(nome .. " nao possui pontos de Sorte!");
                        end;
                    end);
                    message.O_texto_foi_processado = true; return true;
                end;

                -- !efeito NomeCombatente NomeEfeito bonus dano duracao
                if cmd == "efeito" then
                    local parts = {};
                    for w in string.gmatch(texto, "%S+") do table.insert(parts, w); end;
                    if #parts &lt; 5 then
                        chat:enviarMensagem("Uso: !efeito [combatente] [nome] [bonus_atb] [dano/rd] [duracao]");
                        chat:enviarMensagem("Ex: !efeito Aizen Buff +3 0 0");
                    else
                        local comb = buscarCombatente(parts[2]);
                        if comb == nil then
                            chat:enviarMensagem("Combatente '" .. parts[2] .. "' nao encontrado.");
                        else
                            local ef = {nome = parts[3], bonusAtb = tonumber(parts[4]) or 0, danoRodada = tonumber(parts[5]) or 0, duracao = tonumber(parts[6]) or 0, atributos = nil, custoChakraRd = 0};
                            adicionarEfeitoAoCombatente(comb, ef, chat);
                        end;
                    end;
                    message.O_texto_foi_processado = true; return true;
                end;

                -- !sharingan Combatente C/B/A
                if cmd == "sharingan" then
                    local parts = {};
                    for w in string.gmatch(texto, "%S+") do table.insert(parts, w); end;
                    if #parts &lt; 3 then
                        chat:enviarMensagem("Uso: !sharingan [combatente] [C/B/A]");
                    else
                        local comb = buscarCombatente(parts[2]);
                        if comb == nil then
                            chat:enviarMensagem("Combatente '" .. parts[2] .. "' nao encontrado.");
                        else
                            local rank = string.upper(parts[3]);
                            local cfg = nil;
                            if rank == "C" then cfg = {bonus = 2, ativacao = 40, manutencao = 12, label = "1o Estagio (C)"};
                            elseif rank == "B" then cfg = {bonus = 3, ativacao = 70, manutencao = 21, label = "2o Estagio (B)"};
                            elseif rank == "A" then cfg = {bonus = 4, ativacao = 100, manutencao = 30, label = "3o Estagio (A)"};
                            end;
                            if cfg == nil then
                                chat:enviarMensagem("Rank invalido. Use C, B ou A.");
                            else
                                local ef = {nome = "Sharingan-" .. rank, bonusAtb = cfg.bonus, danoRodada = 0, duracao = 0, atributos = SHARINGAN_ATBS, custoChakraRd = cfg.manutencao};
                                chat:enviarMensagem("[SHARINGAN] " .. comb.nome .. " ativa Sharingan " .. cfg.label .. "! Custo: " .. cfg.ativacao .. " chakra.");
                                adicionarEfeitoAoCombatente(comb, ef, chat);
                            end;
                        end;
                    end;
                    message.O_texto_foi_processado = true; return true;
                end;

                -- Handler unificado de efeitos pre-definidos
                local efTemplate = EFEITOS_CMD[cmd];
                if efTemplate ~= nil then
                    local parts = {};
                    for w in string.gmatch(texto, "%S+") do table.insert(parts, w); end;
                    if #parts &lt; 3 then
                        chat:enviarMensagem("Uso: " .. efTemplate.uso);
                    else
                        local comb = buscarCombatente(parts[2]);
                        if comb == nil then
                            chat:enviarMensagem("Combatente '" .. parts[2] .. "' nao encontrado.");
                        else
                            local x = tonumber(parts[3]) or 0;
                            local y = tonumber(parts[4]) or 0;
                            local ef = nil;
                            if efTemplate.tipo == "dano" then
                                ef = {nome = efTemplate.nome, bonusAtb = 0, danoRodada = x, duracao = 0, atributos = nil, custoChakraRd = 0};
                            elseif efTemplate.tipo == "danomult" then
                                local danoFinal = math.floor(x * (efTemplate.mult or 1));
                                ef = {nome = efTemplate.nome, bonusAtb = 0, danoRodada = danoFinal, duracao = 0, atributos = nil, custoChakraRd = 0};
                                chat:enviarMensagem("[EFEITO] Dano calculado: " .. x .. " x " .. (efTemplate.mult or 1) .. " = " .. danoFinal .. "/rd");
                            elseif efTemplate.tipo == "redutor" then
                                ef = {nome = efTemplate.nome, bonusAtb = -x, danoRodada = 0, duracao = 0, atributos = efTemplate.atbs, custoChakraRd = 0};
                            elseif efTemplate.tipo == "hibrido" then
                                ef = {nome = efTemplate.nome, bonusAtb = -x, danoRodada = y, duracao = 0, atributos = efTemplate.atbs, custoChakraRd = 0};
                            elseif efTemplate.tipo == "eletro" then
                                local dur = tonumber(parts[5]) or 0;
                                ef = {nome = efTemplate.nome, bonusAtb = -x, danoRodada = y, duracao = dur, atributos = efTemplate.atbs, custoChakraRd = 0};
                            elseif efTemplate.tipo == "bakuton" then
                                ef = {nome = efTemplate.nome, bonusAtb = -x, danoRodada = 0, duracao = 2, atributos = efTemplate.atbs, custoChakraRd = 0};
                                chat:enviarMensagem("[EFEITO] " .. comb.nome .. ": -" .. x .. " em defesas por 2 rodadas!");
                            elseif efTemplate.tipo == "info" then
                                if cmd == "desintegracao" then
                                    local pct = math.min(x, 10);
                                    chat:enviarMensagem("[EFEITO] " .. comb.nome .. ": Desintegracao! Execucao se PV &lt;= " .. pct .. "%");
                                elseif cmd == "explosao" then
                                    chat:enviarMensagem("[EFEITO] " .. comb.nome .. ": Explosao! +" .. x .. " dano adicional nesta tecnica.");
                                end;
                            elseif efTemplate.tipo == "redutortmp" then
                                -- X = penalidade, Y = rodadas
                                ef = {nome = efTemplate.nome, bonusAtb = -x, danoRodada = 0, duracao = y, atributos = efTemplate.atbs, custoChakraRd = 0};
                            elseif efTemplate.tipo == "afoga" then
                                -- X = dano/rd, Y = estamina/rd, Z = rodadas
                                local z = tonumber(parts[5]) or 0;
                                ef = {nome = efTemplate.nome, bonusAtb = 0, danoRodada = x, estaminaRodada = y, duracao = z, atributos = nil, custoChakraRd = 0};
                                chat:enviarMensagem("[EFEITO] " .. comb.nome .. ": " .. efTemplate.nome .. " - " .. x .. " PV e -" .. y .. " Estamina/rd por " .. z .. " rodadas");
                            elseif efTemplate.tipo == "exaustao" then
                                -- X = penalidade atb (2 rodadas), Y = +estamina custo, Z = tecnicas
                                local z = tonumber(parts[5]) or 0;
                                ef = {nome = efTemplate.nome, bonusAtb = -x, danoRodada = 0, duracao = 2, atributos = efTemplate.atbs, custoChakraRd = 0};
                                chat:enviarMensagem("[EFEITO] " .. comb.nome .. ": Exaustao -" .. x .. " atb por 2 rodadas. +" .. y .. " estamina nas proximas " .. z .. " tecnicas.");
                            elseif efTemplate.tipo == "infotmp" then
                                -- X = valor, Y = rodadas/tecnicas
                                ef = {nome = efTemplate.nome, bonusAtb = 0, danoRodada = 0, duracao = y, atributos = nil, custoChakraRd = 0};
                                chat:enviarMensagem("[EFEITO] " .. comb.nome .. ": " .. efTemplate.nome .. " ativo. Valor: " .. x .. ", Duracao: " .. y .. " rodadas/tecnicas.");
                            end;
                            if ef ~= nil then
                                adicionarEfeitoAoCombatente(comb, ef, chat);
                            end;
                        end;
                    end;
                    message.O_texto_foi_processado = true; return true;
                end;

                -- !efeitos NomeCombatente
                if cmd == "efeitos" then
                    local nomeComb = string.match(texto, "^!efeitos%s+(%S+)");
                    if nomeComb == nil then
                        chat:enviarMensagem("Uso: !efeitos [combatente]");
                    else
                        local comb = buscarCombatente(nomeComb);
                        if comb == nil then
                            chat:enviarMensagem("Combatente '" .. nomeComb .. "' nao encontrado.");
                        else
                            if comb.efeitos == nil or #comb.efeitos == 0 then
                                chat:enviarMensagem(comb.nome .. ": sem efeitos ativos.");
                            else
                                chat:enviarMensagem("Efeitos de " .. comb.nome .. ":");
                                for k = 1, #comb.efeitos do
                                    local ef = comb.efeitos[k];
                                    local durTxt = (ef.duracao ~= nil and ef.duracao > 0) and (ef.duracao .. "rd") or "perm";
                                    local bonTxt = (ef.bonusAtb ~= nil and ef.bonusAtb ~= 0) and ((ef.bonusAtb > 0 and "+" or "") .. ef.bonusAtb .. "atb") or "";
                                    local dmgTxt = (ef.danoRodada ~= nil and ef.danoRodada > 0) and (ef.danoRodada .. "dano/rd") or "";
                                    local chkTxt = (ef.custoChakraRd ~= nil and ef.custoChakraRd > 0) and (ef.custoChakraRd .. "chk/rd") or "";
                                    local atbTxt = "";
                                    if ef.atributos ~= nil then atbTxt = "(" .. #ef.atributos .. " atbs)"; end;
                                    chat:enviarMensagem("  " .. k .. ". " .. ef.nome .. " " .. bonTxt .. " " .. dmgTxt .. " " .. chkTxt .. " " .. atbTxt .. " [" .. durTxt .. "]");
                                end;
                            end;
                        end;
                    end;
                    message.O_texto_foi_processado = true; return true;
                end;

                -- !removerefeito NomeCombatente [numero]
                if cmd == "removerefeito" then
                    local parts = {};
                    for w in string.gmatch(texto, "%S+") do table.insert(parts, w); end;
                    if #parts &lt; 2 then
                        chat:enviarMensagem("Uso: !removerefeito [combatente] - lista efeitos");
                        chat:enviarMensagem("      !removerefeito [combatente] [numero] - remove efeito");
                    else
                        local comb = buscarCombatente(parts[2]);
                        if comb == nil then
                            chat:enviarMensagem("Combatente '" .. parts[2] .. "' nao encontrado.");
                        else
                            local num = tonumber(parts[3]);
                            if num == nil then
                                -- Listar efeitos numerados
                                if comb.efeitos == nil or #comb.efeitos == 0 then
                                    chat:enviarMensagem(comb.nome .. ": sem efeitos ativos.");
                                else
                                    chat:enviarMensagem("Efeitos ativos de " .. comb.nome .. " (digite !removerefeito " .. comb.nome .. " N para remover):");
                                    for k = 1, #comb.efeitos do
                                        local ef = comb.efeitos[k];
                                        local desc = ef.nome;
                                        if ef.bonusAtb ~= nil and ef.bonusAtb ~= 0 then desc = desc .. " " .. (ef.bonusAtb > 0 and "+" or "") .. ef.bonusAtb .. "atb"; end;
                                        if ef.danoRodada ~= nil and ef.danoRodada > 0 then desc = desc .. " " .. ef.danoRodada .. "dano/rd"; end;
                                        if ef.duracao ~= nil and ef.duracao > 0 then desc = desc .. " (" .. ef.duracao .. "rd)";
                                        else desc = desc .. " (perm)"; end;
                                        chat:enviarMensagem("  [" .. k .. "] " .. desc);
                                    end;
                                end;
                            else
                                -- Remover efeito por numero
                                if comb.efeitos == nil or num &lt; 1 or num > #comb.efeitos then
                                    chat:enviarMensagem("Numero invalido. Use !removerefeito " .. comb.nome .. " para ver a lista.");
                                else
                                    local nomeRemovido = comb.efeitos[num].nome;
                                    table.remove(comb.efeitos, num);
                                    chat:enviarMensagem("[EFEITO] Removido #" .. num .. " (" .. nomeRemovido .. ") de " .. comb.nome .. ".");
                                    renderizarTracker();
                                end;
                            end;
                        end;
                    end;
                    message.O_texto_foi_processado = true; return true;
                end;

                -- Comandos de combate
                local info = COMANDOS_COMBATE[cmd];
                if info == nil then return; end;
                buscarFichaEExecutar(mesa, chat, function(sheetNode)
                    local valorAtb = tonumber(sheetNode[info.campo]) or 0;
                    local nome = tostring(sheetNode.nome) or "?";
                    local efBonus = 0;
                    local comb = buscarCombatente(nome);
                    if comb ~= nil then efBonus = calcularBonusEfeitos(comb, info.campo); end;
                    local valorFinal = valorAtb + efBonus;
                    local efTxt = "";
                    if efBonus ~= 0 then efTxt = " (base:" .. valorAtb .. " efeitos:" .. (efBonus > 0 and "+" or "") .. efBonus .. ")"; end;

                    -- Rolar UMA vez localmente para ter o resultado
                    local rolLocal = Firecast.interpretarRolagem("1d20 + " .. valorFinal);
                    if MODO_TESTE then
                        local total = TESTE_VALOR + valorFinal;
                        chat:enviarMensagem("[TESTE] " .. nome .. " rolou 1d20 + " .. valorFinal .. " = " .. total .. efTxt .. " &lt;&lt; " .. info.nome .. " &gt;&gt;");
                        if info.fisico then
                            local estAt = tonumber(sheetNode.pestamina_atual) or 0;
                            local novaEst = estAt - total;
                            sheetNode.pestamina_atual = tostring(novaEst);
                            chat:enviarMensagem("Auto-gasto Estamina: -" .. total .. " (" .. estAt .. " -> " .. novaEst .. ")");
                            verificarZeroStatus(sheetNode, chat, nome);
                        end;
                    else
                        if info.fisico then
                            -- Para fisico: rola local, mostra resultado e gasta estamina com o MESMO valor
                            rolLocal:rolarLocalmente();
                            local resultado = rolLocal.resultado or 0;
                            chat:enviarMensagem(nome .. " rolou 1d20 + " .. valorFinal .. " = " .. resultado .. efTxt .. " &lt;&lt; " .. info.nome .. " &gt;&gt;");
                            local estAt = tonumber(sheetNode.pestamina_atual) or 0;
                            local novaEst = estAt - resultado;
                            sheetNode.pestamina_atual = tostring(novaEst);
                            chat:enviarMensagem("Auto-gasto Estamina: -" .. resultado .. " (" .. estAt .. " -> " .. novaEst .. ")");
                            -- Atualizar barra da sala
                            local combAt = buscarCombatente(nome);
                            if combAt ~= nil and combAt.tipo == "jogador" then
                                local barId = combAt.login or nome;
                                chat:enviarMensagem("/estamina " .. barId .. " -" .. resultado);
                            end;
                            verificarZeroStatus(sheetNode, chat, nome);
                        else
                            -- Para nao-fisico: usa rolarDados normal (visual bonito)
                            chat:rolarDados(rolLocal, info.nome .. " de " .. nome .. efTxt);
                        end;
                    end;
                end);
                message.O_texto_foi_processado = true; return true;
            end
        );
    </script>

    <layout align="client">
        <rectangle align="client" color="#1A1D23"/>
        <layout align="top" height="30" margins="{left=4, right=4, top=4}">
            <button name="btnAddNpcToggle" align="left" width="30" text="+" fontColor="#CCCCCC" fontSize="16" onClick="toggleNpcPanel()"/>
            <button name="btnRolarIni" align="left" width="30" text="R" fontColor="#FBBF24" fontSize="13" onClick="rolarIniciativas()"/>
            <button name="btnAddJogadores" align="left" width="30" text="A" fontColor="#22C55E" fontSize="13" onClick="adicionarJogadores()"/>
            <label align="client" text="COMBAT TRACKER" fontColor="#4FC3F7" fontSize="12" horzTextAlign="center" vertTextAlign="center"/>
            <button name="btnCloseOverlay" align="right" width="22" text="X" fontColor="#FF6B6B" fontSize="11" onClick="fecharOverlay()"/>
            <button name="btnGuiExplorer" align="right" width="30" text="G" fontColor="#FFD700" fontSize="13" onClick="explorarGUI()"/>
            <button name="btnFichaDemo" align="right" width="30" text="D" fontColor="#4FC3F7" fontSize="13" onClick="fichaDemo()"/>
            <button name="btnTestFcext" align="right" width="30" text="F" fontColor="#AB47BC" fontSize="13" onClick="testarFcext()"/>
            <button name="btnLimpar" align="right" width="45" text="Clear" fontColor="#EF5350" fontSize="10" onClick="limparTracker()"/>
        </layout>
        <layout name="pnlNpcInput" align="top" height="28" visible="false" margins="{left=4, right=4, top=2}">
            <edit name="edtNpcNome" align="left" width="100" fontColor="white"/>

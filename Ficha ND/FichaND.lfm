                                <edit align="left" width="60" field="concentracao" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="180" text="Força Espiritual:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="forca_espiritual" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="180" text="Inteligência:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="inteligencia" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            
                            <!-- Limite de Atributo -->
                            <layout align="top" height="35" margins="{top=12}">
                                <rectangle align="client" color="#1A1A2E" strokeColor="#FFD93D" strokeSize="1" xradius="6" yradius="6"/>
                                <label align="left" width="185" text="Limite de Atributo:" horzTextAlign="trailing" margins="{right=10}" fontColor="#AADDFF" fontSize="13" fontStyle="bold"/>
                                <label align="left" width="55" field="limite_atributo" fontColor="#AADDFF" fontSize="15" fontStyle="bold" horzTextAlign="center"/>
                                <label align="client" text="(Soma Core ÷ 8) +3" fontColor="#666666" fontSize="10" fontStyle="italic"/>
                            </layout>
                            <!-- Pontos Core -->
                            <layout align="top" height="28" margins="{top=6}">
                                <rectangle align="client" color="#141428" strokeColor="#2A2A4E" strokeSize="1" xradius="6" yradius="6"/>
                                <label align="client" field="pontos_core_resumo" horzTextAlign="center" fontColor="#FFD700" fontSize="12" fontStyle="bold"/>
                            </layout>
                        </layout>
                        
<!-- === COLUNA DIREITA: Atributos Interpretativos === -->
                        <layout left="450" top="0" width="430" height="560">
                            <layout align="top" height="25">
                                <rectangle align="client" color="#1A1A2E" strokeColor="#4ECDC4" strokeSize="1" xradius="6" yradius="6"/>
                                <label align="client" text="Atributos Interpretativos" horzTextAlign="center" fontColor="#FFD700" fontSize="13" fontStyle="bold"/>
                            </layout>
                            

                            <layout align="top" height="30" margins="{top=4}">
                                <label align="left" width="160" text="Sobrevivência:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="sobrevivencia" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">

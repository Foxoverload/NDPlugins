                                <edit align="left" width="60" field="persuasao" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="160" text="Sedução:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="seducao" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">

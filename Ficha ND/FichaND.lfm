                                <edit align="left" width="60" field="armadilha" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="160" text="Empatia:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="empatia" fontColor="white" horzTextAlign="center"/>
                            </layout>

                            <comboBox align="client" name="cb13" hitTest="false" field="defeito5" fontColor="white" items="{'Nenhum','Código de Honra','Curiosidade','Hábito Detestável','Fanatismo','Pobreza','Pesadelos','Intolerância','Imprevisível','Esquecido','Esnobe','Excesso de Confiança','Timidez','Dificuldade de Fala','Sadismo ou Masoquismo','Obsessão','Vingança','Ódio','Pacifista','Má Fama','Fanfarronice','Sanguinolência','Hábito Negativo','Segredo Sombrio','Mentiroso','Covardia','Honestidade','Impulsividade','Ninja Orgulhoso','Lealdade Inabalável','Fair Play','Pervertido','Cabeça Quente','Sede de Poder'}" values="{'','Código de Honra','Curiosidade','Hábito Detestável','Fanatismo','Pobreza','Pesadelos','Intolerância','Imprevisível','Esquecido','Esnobe','Excesso de Confiança','Timidez','Dificuldade de Fala','Sadismo ou Masoquismo','Obsessão','Vingança','Ódio','Pacifista','Má Fama','Fanfarronice','Sanguinolência','Hábito Negativo','Segredo Sombrio','Mentiroso','Covardia','Honestidade','    Impulsividade','Ninja Orgulhoso','Lealdade Inabalável','Fair Play','Pervertido','Cabeça Quente','Sede de Poder'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb13:dropDown();</event></layout>
                        </layout>
                    </layout>

                    <cabecalho texto="Família e Amigos" />
                    
                    <layout align="top" height="20" margins="{top=2, bottom=5}">
                        <label align="left" width="800" text="(Os campos abaixo são Opcionais de acordo com a narração/mestre)" horzTextAlign="center" fontColor="#8888AA" fontSize="11" fontStyle="italic"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Pais:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="familia_pais" fontColor="white" textPrompt="Nome do Pai e Nome da Mãe do Personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Irmã(os):" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="familia_irmaos" fontColor="white" textPrompt="Nome dos irmãos e idade deles em parênteses"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Relativos:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="familia_relativos" fontColor="white" textPrompt="Nome dos tios, tias, avôs, Avós e/ou primos"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Amigos:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="familia_amigos" fontColor="white" textPrompt="Quais são os amigos do seu personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Neutros:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="familia_neutros" fontColor="white" textPrompt="Nome das pessoas que o personagem conhece mas não é amigo ou inimigo"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Inimigos:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="familia_inimigos" fontColor="white" textPrompt="Quais são os inimigos do seu personagem"/>
                    </layout>
                    
                    <cabecalho texto="Informações Ninjas" />
                    
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Vila de Nascimento:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="vila_nascimento" fontColor="white" textPrompt="Vila de nascimento do personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Rank Shinobi:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="200" height="30">
                            <rectangle align="client" color="#141428" strokeColor="#2A2A4E" strokeSize="1" xradius="6" yradius="6"/>
                            <label align="client" field="rank_shinobi" fontColor="#FFD700" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                        </layout>
                    </layout>
                    
                    <script>
                        local function calcularRank()
                            if sheet == nil then return end;
                            local nivel = tonumber(sheet.nivel) or 0;
                            local rank;
                            if nivel >= 160 then
                                rank = "Fushi";
                            elseif nivel >= 140 then
                                rank = "Kage";
                            elseif nivel >= 120 then
                                rank = "Sannin";
                            elseif nivel >= 90 then
                                rank = "Oinin";
                            elseif nivel >= 80 then
                                rank = "Nukenin";
                            elseif nivel >= 60 then
                                rank = "Comandante ANBU";
                            elseif nivel >= 50 then
                                rank = "ANBU";
                            elseif nivel >= 40 then
                                rank = "Capitão Jõnin";
                            elseif nivel >= 30 then
                                rank = "Jõnin";
                            elseif nivel >= 20 then
                                rank = "Tokubetsu Jõnin";
                            elseif nivel >= 10 then
                                rank = "Chunin";
                            elseif nivel >= 4 then
                                rank = "Genin";
                            else
                                rank = "Estudante";
                            end
                            sheet.rank_shinobi = rank;
                            
                            -- Calcular máximo de pontos interpretativos por rank
                            local maxInterp;
                            if     rank == "Estudante"       then maxInterp = 20;
                            elseif rank == "Genin"           then maxInterp = 24;
                            elseif rank == "Chunin"          then maxInterp = 30;
                            elseif rank == "Tokubetsu Jõnin" then maxInterp = 32;
                            elseif rank == "Jõnin"           then maxInterp = 34;
                            elseif rank == "Capitão Jõnin"  then maxInterp = 36;
                            elseif rank == "ANBU"            then maxInterp = 38;
                            elseif rank == "Comandante ANBU" then maxInterp = 40;
                            elseif rank == "Nukenin"         then maxInterp = 42;
                            elseif rank == "Oinin"           then maxInterp = 44;
                            elseif rank == "Sannin"          then maxInterp = 46;
                            elseif rank == "Kage"            then maxInterp = 48;
                            elseif rank == "Fushi"           then maxInterp = 50;
                            else maxInterp = 0;
                            end
                            sheet.max_pontos_interp = tostring(maxInterp);
                        end
                    </script>
                    
                    <dataLink fields="{'nivel'}">
                        <event name="onChange">
                            calcularRank();
                        </event>
                    </dataLink>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Sensei:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="sensei" fontColor="white" textPrompt="Senseis ou mentores do personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Kuchiyose:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="kuchiyose" fontColor="white" textPrompt="Caso possua, qual o Nome do animal ou objeto que o personagem possuí contrato"/>
                    </layout>

                    <layout align="top" height="48" margins="{top=5}">
                        <label align="left" width="160" text="Natureza:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        
                        <!-- Fogo -->
                        <layout align="left" width="95" height="48">
                            <image left="38" top="2" width="18" height="18" src="/Imagens/Elementos/Nature_Icon_Fire.webp"/>
                            <checkBox left="15" top="24" height="20" field="elem_fogo" text="Katon" fontColor="#FF6633" fontSize="12"/>
                        </layout>
                        
                        <!-- Água -->
                        <layout align="left" width="95" height="48">
                            <image left="38" top="2" width="18" height="18" src="/Imagens/Elementos/Nature_Icon_Water.webp"/>
                            <checkBox left="13" top="24" height="20" field="elem_agua" text="Suiton" fontColor="#3399FF" fontSize="12"/>
                        </layout>
                        
                        <!-- Terra -->
                        <layout align="left" width="95" height="48">
                            <image left="38" top="2" width="18" height="18" src="/Imagens/Elementos/Nature_Icon_Earth.webp"/>
                            <checkBox left="15" top="24" height="20" field="elem_terra" text="Doton" fontColor="#CC9933" fontSize="12"/>
                        </layout>
                        
                        <!-- Vento -->
                        <layout align="left" width="95" height="48">
                            <image left="38" top="2" width="18" height="18" src="/Imagens/Elementos/Nature_Icon_Wind.webp"/>
                            <checkBox left="16" top="24" height="20" field="elem_vento" text="Fūton" fontColor="#66CC99" fontSize="12"/>
                        </layout>
                        
                        <!-- Raio -->
                        <layout align="left" width="95" height="48">
                            <image left="38" top="2" width="18" height="18" src="/Imagens/Elementos/Nature_Icon_Lightning.webp"/>
                            <checkBox left="13" top="24" height="20" field="elem_raio" text="Raiton" fontColor="#FFFF33" fontSize="12"/>
                        </layout>
                    </layout>

                    <!-- Combinações Elementais Detectadas -->
                    <layout align="top" height="25" margins="{top=4}">
                        <label align="left" width="160" text="Combinação:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <label align="client" field="elem_combo" fontColor="#FF9944" fontSize="12" fontStyle="bold italic"/>
                    </layout>

                    <script>
                        local function calcularCombinacaoElemental()
                            if sheet == nil then return end;
                            local fogo  = tostring(sheet.elem_fogo)  == "true";
                            local agua  = tostring(sheet.elem_agua)  == "true";
                            local terra = tostring(sheet.elem_terra) == "true";
                            local vento = tostring(sheet.elem_vento) == "true";
                            local raio  = tostring(sheet.elem_raio)  == "true";
                            
                            local combos = {};
                            if fogo and raio  then table.insert(combos, "Enton (Inferno)"); end
                            if fogo and agua  then table.insert(combos, "Futton (Fervura)"); end
                            if fogo and terra then table.insert(combos, "Youton (Lava)"); end
                            if fogo and vento then table.insert(combos, "Shakuton (Calor)"); end
                            if terra and agua  then table.insert(combos, "Mokuton (Madeira)"); end
                            if vento and agua  then table.insert(combos, "Hyouton (Gelo)"); end
                            if raio  and agua  then table.insert(combos, "Ranton (Tempestade)"); end
                            if vento and terra then table.insert(combos, "Jiton (Magnetismo)"); end
                            if raio  and terra then table.insert(combos, "Bakuton (Explosão)"); end
                            if fogo and terra and raio then table.insert(combos, "Kouton (Aço)"); end
                            if vento and terra and agua then table.insert(combos, "Shouton (Cristal)"); end
                            if vento and terra and fogo then table.insert(combos, "Jinton (Partícula)"); end
                            if raio  and agua  and vento then table.insert(combos, "Meiton (Escuridão)"); end
                            
                            if #combos > 0 then
                                sheet.elem_combo = table.concat(combos, ", ");
                            else
                                sheet.elem_combo = "Nenhuma";
                            end
                        end
                    </script>
                    
                    <dataLink fields="{'elem_fogo','elem_agua','elem_terra','elem_vento','elem_raio'}">
                        <event name="onChange">
                            calcularCombinacaoElemental();
                        </event>
                    </dataLink>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Clã:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="cla_ninja" fontColor="white" textPrompt=""/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Kekkei Genkai:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="kekkei_genkai" fontColor="white" textPrompt=""/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Tipo Sanguíneo:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="200">
                            <comboBox align="client" name="cb14" hitTest="false" field="tipo_sanguineo" fontColor="white" items="{'Selecione...','A','B','AB','O'}" values="{'','A','B','AB','O'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb14:dropDown();</event></layout>
                        </layout>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Mão Dominante:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="200">
                            <comboBox align="client" name="cb15" hitTest="false" field="mao_dominante" items="{'Canhoto', 'Destro', 'Ambidestro (Trait)'}" values="{'Canhoto', 'Destro', 'Ambidestro'}" fontColor="white"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb15:dropDown();</event></layout>
                        </layout>
                    </layout>

                    <!-- ====== RECONHECIMENTO ====== -->
                    <layout align="top" height="20" margins="{top=10, bottom=2}">
                        <rectangle align="client" color="#1A1A2E" strokeColor="#FF6B35" strokeSize="1" xradius="6" yradius="6"/>
                        <label align="client" text="Reconhecimento" horzTextAlign="center" fontColor="#FFD700" fontSize="12" fontStyle="bold"/>
                    </layout>
                    
                    <!-- Natureza da fama -->
                    <layout align="top" height="30" margins="{top=4}">
                        <label align="left" width="160" text="Natureza:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="250">
                            <comboBox align="client" name="cb16" hitTest="false" field="rec_natureza" items="{'☆ Invisível (sem natureza)', '★ Renome (Dourado/Azul)', '★ Infâmia (Vermelho/Laranja)'}" values="{'0','1','2'}" fontColor="white"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb16:dropDown();</event></layout>
                        </layout>
                    </layout>
                    
                    <!-- 6 Estrelas clicáveis -->
                    <layout align="top" height="35" margins="{top=6}">
                        <label align="left" width="160" text="Estrelas:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <checkBox align="left" width="28" field="rec_star1" text="" fontColor="#FFD700"/>
                        <checkBox align="left" width="28" field="rec_star2" text="" fontColor="#FFD700"/>
                        <checkBox align="left" width="28" field="rec_star3" text="" fontColor="#FFD700"/>
                        <checkBox align="left" width="28" field="rec_star4" text="" fontColor="#FFD700"/>
                        <checkBox align="left" width="28" field="rec_star5" text="" fontColor="#FFD700"/>
                        <checkBox align="left" width="28" field="rec_star6" text="" fontColor="#FFD700"/>
                        <layout align="left" width="10"/>
                        <label align="client" field="rec_estrelas_fmt" fontSize="20" fontColor="#FFD700" horzTextAlign="leading"/>
                    </layout>
                    
                    <!-- Titulo automático -->
                    <layout align="top" height="32" margins="{top=6}">
                        <rectangle align="client" color="#141428" strokeColor="#2A2A4E" strokeSize="1" xradius="6" yradius="6"/>
                        <label align="left" width="160" text="Título:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <label align="client" field="rec_titulo" fontColor="#FFD700" fontSize="14" fontStyle="bold" horzTextAlign="leading"/>
                    </layout>
                    
                    <!-- Descrição da fama -->
                    <layout align="top" height="15" margins="{top=6, bottom=2}">
                        <label align="client" text="Motivo da fama / infâmia:" fontColor="#8888AA" fontSize="11" fontStyle="italic"/>
                    </layout>
                    <textEditor align="top" height="70" field="rec_descricao" fontColor="white" transparent="false"/>
                    
                    <script>
                        local function calcularReconhecimento()
                            if sheet == nil then return end;
                            
                            -- Contar estrelas marcadas (tostring() trata boolean true E string "true")
                            local count = 0;
                            if tostring(sheet.rec_star1) == "true" then count = count + 1; end
                            if tostring(sheet.rec_star2) == "true" then count = count + 1; end
                            if tostring(sheet.rec_star3) == "true" then count = count + 1; end
                            if tostring(sheet.rec_star4) == "true" then count = count + 1; end
                            if tostring(sheet.rec_star5) == "true" then count = count + 1; end
                            if tostring(sheet.rec_star6) == "true" then count = count + 1; end
                            
                            -- Cor das estrelas conforme natureza
                            local natureza = sheet.rec_natureza or "0";
                            local strOn, strOff;
                            if natureza == "2" then
                                -- Infâmia: estrelas vermelhas (laranja)
                                strOn  = "\226\152\133"; -- ★
                                strOff = "\226\152\134"; -- ☆
                            else
                                -- Renome ou invisível: estrelas douradas
                                strOn  = "\226\152\133"; -- ★
                                strOff = "\226\152\134"; -- ☆
                            end
                            
                            -- Montar display das estrelas
                            local estrelas = "";
                            for i = 1, 6 do
                                if not (i > count) then
                                    estrelas = estrelas .. strOn;
                                else
                                    estrelas = estrelas .. strOff;
                                end
                            end
                            sheet.rec_estrelas_fmt = estrelas;
                            
                            -- Título automático
                            local titulo;
                            if count == 0 then
                                titulo = "Invisível";
                            elseif count == 1 then
                                titulo = "Comum";
                            elseif count == 2 then
                                titulo = "Herdeiro";
                            elseif count == 3 then
                                titulo = "Local";
                            elseif count == 4 then
                                titulo = "Regional";
                            elseif count == 5 then
                                titulo = "Mundial";
                            else
                                titulo = "Lenda";
                            end
                            sheet.rec_titulo = titulo;
                        end
                    </script>
                    
                    <dataLink fields="{'rec_star1','rec_star2','rec_star3','rec_star4','rec_star5','rec_star6','rec_natureza'}">
                        <event name="onChange">
                            calcularReconhecimento();
                        </event>
                    </dataLink>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Organização:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="organizacao" fontColor="white" textPrompt="(Opcional, somente usado de acordo com a narração/mestre)"/>
                    </layout>



                    <layout align="top" height="30" margins="{top=15, bottom=5}">
                        <rectangle align="client" color="#141428" strokeColor="#FF6B35" strokeSize="2" xradius="8" yradius="8"/>
                        <label align="client" field="trait_resumo" horzTextAlign="center" vertTextAlign="center" fontStyle="bold" fontColor="white" fontSize="15"/>
                    </layout>
                    
                    <layout align="top" height="20" margins="{top=2, bottom=5}">
                        <label align="left" width="800" text="Formato para somar automaticamente: Nome do Trait (XXX pontos de Trait)" horzTextAlign="center" fontColor="#8888AA" fontSize="11" fontStyle="italic"/>
                    </layout>
                    <layout align="top" height="16" margins="{bottom=5}">
                        <label align="left" width="800" text="Bônus nos cálculos: [bônus: CAMPO +N]  ex: [bônus: forca +2]  [bônus: pv +500]" horzTextAlign="center" fontColor="#7799AA" fontSize="10" fontStyle="italic"/>
                    </layout>
                    <layout align="top" height="18" margins="{bottom=3}">
                        <label align="client" field="trait_bonus_resumo" horzTextAlign="center" fontColor="#44BBFF" fontSize="11" fontStyle="bold"/>
                    </layout>
                    
                    <!-- Script LUA para calcular automaticamente os Traits -->
                    <script>
                        local function calcularTraits()
                            if sheet == nil then return end;
                            
                            -- Calcular o máximo baseado no nível
                            local nivel = tonumber(sheet.nivel) or 0;
                            local max = 450 + (nivel * 10);
                            
                            -- Ler o texto puro diretamente do controle textEditor
                            local gasto = 0;
                            local texto = "";
                            
                            if self.edtTraits ~= nil then
                                texto = self.edtTraits:getText() or "";
                            end
                            
                            -- Procura todos os padrões '(NUMERO pontos de Trait)' case insensitive
                            if texto ~= "" then
                                for valor in string.gmatch(texto:lower(), "%((%d+)%s*pontos.-trait%)") do
                                    gasto = gasto + tonumber(valor);
                                end
                            end
                            
                            -- Atualiza o label centralizado
                            sheet.trait_resumo = "Trait [ " .. gasto .. " / " .. max .. " ]";
                            
                            -- === Parsear bônus de traits ===
                            -- Atributos de combate: [bônus: CAMPO +N] (valor flat)
                            -- Status:               [bônus: pv +25%]  (multiplicador %)
                            local cambosCombate = {'taijutsu','bukijutsu','ninjutsu','genjutsu','genjutsu_kai','fuinjutsu','arremesso','esquiva','bloqueio_fisico','bloqueio_chakra','reflexo','iniciativa','tai_bukijutsu','nin_taijutsu','hiraishin','movimentacao'};
                            local camposStatus  = {'pv','pchakra','pestamina'};
                            
                            local totaisBonus = {};
                            for _, c in ipairs(cambosCombate) do totaisBonus[c] = 0; end
                            for _, c in ipairs(camposStatus)  do totaisBonus[c] = 0; end
                            
                            local textoLower = texto:lower();
                            
                            -- Flat: [bonus: CAMPO +/-N]
                            for campo, sinal, valor in string.gmatch(textoLower, "%[b%o*nus:%s*([%a_]+)%s*([%+%-])(%d+)%]") do
                                if totaisBonus[campo] ~= nil then
                                    local n = tonumber(valor) or 0;
                                    if sinal == "-" then n = -n; end
                                    totaisBonus[campo] = totaisBonus[campo] + n;
                                end
                            end
                            
                            -- Percentual: [bonus: CAMPO +/-N%]
                            for campo, sinal, valor in string.gmatch(textoLower, "%[b%o*nus:%s*([%a_]+)%s*([%+%-])(%d+)%%%]") do
                                if totaisBonus[campo] ~= nil then
                                    local n = tonumber(valor) or 0;
                                    if sinal == "-" then n = -n; end
                                    totaisBonus[campo] = totaisBonus[campo] + n;
                                end
                            end
                            
                            -- Salvar bônus no sheet
                            for campo, v in pairs(totaisBonus) do
                                sheet["bonus_" .. campo] = tostring(v);
                            end
                            
                            -- Gerar resumo dos bônus ativos
                            local resumoBonus = "";
                            for _, c in ipairs(cambosCombate) do
                                local v = totaisBonus[c];
                                if v ~= 0 then
                                    local s = v > 0 and "+" or "";
                                    resumoBonus = resumoBonus .. c .. ": " .. s .. v .. "  ";
                                end
                            end
                            for _, c in ipairs(camposStatus) do
                                local v = totaisBonus[c];
                                if v ~= 0 then
                                    local s = v > 0 and "+" or "";
                                    resumoBonus = resumoBonus .. c .. ": " .. s .. v .. "%  ";
                                end
                            end
                            if resumoBonus ~= "" then
                                sheet.trait_bonus_resumo = "Bônus: " .. resumoBonus;
                            else
                                sheet.trait_bonus_resumo = "";
                            end
                            
                            -- Recalcular atributos com os novos bônus
                            if calcularAtributos ~= nil then
                                calcularAtributos();
                            end
                        end
                    </script>
                    
                    <richEdit name="edtTraits" align="top" height="250" field="traits" defaultFontColor="white" backgroundColor="#1A1A1A" defaultFontSize="13" hideSelection="false" animateImages="true" margins="{top=5, left=10, right=10}">
                    </richEdit>
                    
                    <!-- Gatilho secundário: recalcular quando o nível muda -->
                    <dataLink fields="{'nivel'}">
                        <event name="onChange">
                            calcularTraits();
                        </event>
                    </dataLink>
                    
                    <cabecalho texto="Aparência" />
                    
                    <layout align="top" height="20" margins="{top=2, bottom=2}">
                        <label align="client" text="Clique nas imagens abaixo para selecionar fotos do personagem" horzTextAlign="center" fontColor="#8888AA" fontSize="11" fontStyle="italic"/>
                    </layout>
                    
                    <layout align="top" height="280" margins="{top=5, bottom=10}">
                        <!-- Imagem 1 -->
                        <layout left="20" top="0" width="270" height="280">
                            <layout align="top" height="250">
                                <rectangle align="client" color="#1A1A2E" strokeColor="#2A2A4E" strokeSize="1" xradius="8" yradius="8"/>
                                <image align="client" field="aparencia_img1" editable="true" style="autoFit"/>
                            </layout>
                            <label align="top" height="25" text="Imagem 1" horzTextAlign="center" fontColor="#AAAAAA" fontSize="11" margins="{top=5}"/>
                        </layout>
                        
                        <!-- Imagem 2 -->
                        <layout left="310" top="0" width="270" height="280">
                            <layout align="top" height="250">
                                <rectangle align="client" color="#1A1A2E" strokeColor="#2A2A4E" strokeSize="1" xradius="8" yradius="8"/>
                                <image align="client" field="aparencia_img2" editable="true" style="autoFit"/>
                            </layout>
                            <label align="top" height="25" text="Imagem 2" horzTextAlign="center" fontColor="#AAAAAA" fontSize="11" margins="{top=5}"/>
                        </layout>
                        
                        <!-- Imagem 3 -->
                        <layout left="600" top="0" width="270" height="280">
                            <layout align="top" height="250">
                                <rectangle align="client" color="#1A1A2E" strokeColor="#2A2A4E" strokeSize="1" xradius="8" yradius="8"/>
                                <image align="client" field="aparencia_img3" editable="true" style="autoFit"/>
                            </layout>
                            <label align="top" height="25" text="Imagem 3" horzTextAlign="center" fontColor="#AAAAAA" fontSize="11" margins="{top=5}"/>
                        </layout>
                    </layout>
                    
                    <!-- ====== ATRIBUTOS ====== -->
                    <cabecalho texto="Atributos" />
                    

                    <!-- Pontos de Vida / Chakra / Estamina (atual / máximo) -->
                    <layout align="top" height="110" margins="{top=10}">
                        <!-- PV -->
                        <layout name="rowBarraPv" align="top" height="30" margins="{top=2}">
                            <label align="left" width="160" text="Pontos de Vida:" horzTextAlign="trailing" margins="{right=10}" fontColor="#FF6666" fontSize="13" fontStyle="bold"/>
                            <edit align="left" width="55" field="pv_atual" fontColor="white" horzTextAlign="center"/>
                            <label align="left" width="20" text=" / " fontColor="#AAAAAA" fontSize="13" horzTextAlign="center"/>
                            <label align="left" width="55" field="pv" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                            <layout align="left" width="10" height="30"/>
                            <layout name="containerBarraPv" align="client" height="30" margins="{top=5, bottom=5}">
                                <rectangle name="barraPvFundo" align="client" color="#1A0A0E" strokeColor="#331111" strokeSize="1" xradius="6" yradius="6"/>
                                <rectangle name="barraPv" align="left" width="0" color="#22CC55" xradius="6" yradius="6"/>
                            </layout>
                        </layout>
                        <layout name="rowBarraChakra" align="top" height="30" margins="{top=5}">
                            <label align="left" width="160" text="Pontos de Chakra:" horzTextAlign="trailing" margins="{right=10}" fontColor="#6699FF" fontSize="13" fontStyle="bold"/>
                            <edit align="left" width="55" field="pchakra_atual" fontColor="white" horzTextAlign="center"/>
                            <label align="left" width="20" text=" / " fontColor="#AAAAAA" fontSize="13" horzTextAlign="center"/>
                            <label align="left" width="55" field="pchakra" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                            <layout align="left" width="10" height="30"/>
                            <layout name="containerBarraChakra" align="client" height="30" margins="{top=5, bottom=5}">
                                <rectangle name="barraChakraFundo" align="client" color="#0A0E1A" strokeColor="#111133" strokeSize="1" xradius="6" yradius="6"/>
                                <rectangle name="barraChakra" align="left" width="0" color="#3388FF" xradius="6" yradius="6"/>
                            </layout>
                        </layout>
                        <layout name="rowBarraEstamina" align="top" height="30" margins="{top=5}">
                            <label align="left" width="160" text="Pontos de Estamina:" horzTextAlign="trailing" margins="{right=10}" fontColor="#66CC66" fontSize="13" fontStyle="bold"/>
                            <edit align="left" width="55" field="pestamina_atual" fontColor="white" horzTextAlign="center"/>
                            <label align="left" width="20" text=" / " fontColor="#AAAAAA" fontSize="13" horzTextAlign="center"/>
                            <label align="left" width="55" field="pestamina" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                            <layout align="left" width="10" height="30"/>
                            <layout name="containerBarraEstamina" align="client" height="30" margins="{top=5, bottom=5}">
                                <rectangle name="barraEstaminaFundo" align="client" color="#0A1A0E" strokeColor="#113311" strokeSize="1" xradius="6" yradius="6"/>
                                <rectangle name="barraEstamina" align="left" width="0" color="#4ECDC4" xradius="6" yradius="6"/>
                            </layout>
                        </layout>
                    </layout>
                    
                    <!-- Traits de Status -->
                    <layout align="top" height="22" margins="{top=12, bottom=2}">
                        <rectangle align="client" color="#141428" strokeColor="#2A2A4E" strokeSize="1" xradius="6" yradius="6"/>
                        <label align="client" text="Traits de Status" horzTextAlign="center" fontColor="#FFD700" fontSize="12" fontStyle="bold"/>
                    </layout>
                    
                    <layout align="top" height="60" margins="{top=6}">
                        <!-- PV Trait -->
                        <layout align="left" width="290" height="60">
                            <label align="top" height="18" text="Trait de Vida:" fontColor="#FF6666" fontSize="11" fontStyle="bold" horzTextAlign="center"/>
                            <layout align="top" height="28">
                                <comboBox align="client" name="cb17" hitTest="false" field="trait_pv" items="{'Nenhum','Vida Extra: ★ ☆ ☆ ☆ ☆ ☆ (+5%)','Vida Extra: ★ ★ ☆ ☆ ☆ ☆ (+10%)','Vida Extra: ★ ★ ★ ☆ ☆ ☆ (+15%)','Vida Extra: ★ ★ ★ ★ ☆ ☆ (+20%)','Vida Extra: ★ ★ ★ ★ ★ ☆ (+25%)','Reencarnação de Asura (+25%)','Linhagem de Hagoromo/Hamura (+35%)','Híbrido: Meio-Õtsutsuki (+60%)','Clã Õtsutsuki (+100%)'}" values="{'0','5','10','15','20','25','25','35','60','100'}" fontColor="white" fontSize="11"/>
                                <layout align="client" hitTest="true"><event name="onClick">self.cb17:dropDown();</event></layout>
                            </layout>
                        </layout>
                        <layout align="left" width="10" height="60"/>
                        <!-- Chakra Trait -->
                        <layout align="left" width="280" height="60">
                            <label align="top" height="18" text="Trait de Chakra:" fontColor="#6699FF" fontSize="11" fontStyle="bold" horzTextAlign="center"/>
                            <layout align="top" height="28">
                                <comboBox align="client" name="cb18" hitTest="false" field="trait_pchakra" items="{'Nenhum','Chakra Extra: ★ ☆ ☆ ☆ ☆ ☆ (+5%)','Chakra Extra: ★ ★ ☆ ☆ ☆ ☆ (+10%)','Chakra Extra: ★ ★ ★ ☆ ☆ ☆ (+15%)','Chakra Extra: ★ ★ ★ ★ ☆ ☆ (+20%)','Chakra Extra: ★ ★ ★ ★ ★ ☆ (+25%)','Células de Hashirama (+25%)','Pseudo Jinchūriki (+25%)','Jinchūriki do Ichibi (+25%)','Jinchūriki do Nibi (+30%)','Jinchūriki do Sanbi (+35%)','Jinchūriki do Yonbi (+35%)','Jinchūriki do Gobi (+35%)','Jinchūriki do Rokubi (+40%)','Jinchūriki do Nanabi (+45%)','Jinchūriki do Hachibi (+50%)','Jinchūriki do Kyūii (+55%)','Jinchūriki do Jūbi (+100%)','Reencarnação de Indra (+40%)','Reencarnação de Asura (+25%)','Linhagem de Hagoromo/Hamura (+35%)','Híbrido: Meio-Õtsutsuki (+60%)','Clã Õtsutsuki (+100%)'}" values="{'0','5','10','15','20','25','25','25','25','30','35','35','35','40','45','50','55','100','40','25','35','60','100'}" fontColor="white" fontSize="11"/>
                                <layout align="client" hitTest="true"><event name="onClick">self.cb18:dropDown();</event></layout>
                            </layout>
                        </layout>
                        <layout align="left" width="10" height="60"/>
                        <!-- Estamina Trait -->
                        <layout align="client" height="60">
                            <label align="top" height="18" text="Trait de Estâmina:" fontColor="#66CC66" fontSize="11" fontStyle="bold" horzTextAlign="center"/>
                            <layout align="top" height="28">
                                <comboBox align="client" name="cb19" hitTest="false" field="trait_pestamina" items="{'Nenhum','Estâmina Extra: ★ ☆ ☆ ☆ ☆ ☆ (+5%)','Estâmina Extra: ★ ★ ☆ ☆ ☆ ☆ (+10%)','Estâmina Extra: ★ ★ ★ ☆ ☆ ☆ (+15%)','Estâmina Extra: ★ ★ ★ ★ ☆ ☆ (+20%)','Estâmina Extra: ★ ★ ★ ★ ★ ☆ (+25%)','Reencarnação de Asura (+25%)','Linhagem de Hagoromo/Hamura (+35%)','Híbrido: Meio-Õtsutsuki (+60%)','Clã Õtsutsuki (+100%)'}" values="{'0','5','10','15','20','25','25','35','60','100'}" fontColor="white" fontSize="11"/>
                                <layout align="client" hitTest="true"><event name="onClick">self.cb19:dropDown();</event></layout>
                            </layout>
                        </layout>
                    </layout>
                    <layout align="top" height="30" margins="{top=5, bottom=2}">
                        <label align="client" text="* Somente um atributo interpretativo pode chegar a 10, outros dois podem estar em 8. Os demais atingem máximo de 7." horzTextAlign="center" fontColor="#CCAA44" fontSize="10" fontStyle="italic"/>
                    </layout>
                    <layout align="top" height="20" margins="{bottom=3}">
                        <label align="client" field="aviso_interp" horzTextAlign="center" fontColor="#FF4444" fontSize="11" fontStyle="bold"/>
                    </layout>
                    
                    <!-- Atributos Core (esquerda) + Interpretativos (direita) -->
                    <layout align="top" height="560" margins="{top=5}">
                        
                        <!-- === COLUNA ESQUERDA: Atributos Core === -->
                        <layout left="0" top="0" width="430" height="560">
                            <layout align="top" height="25">
                                <rectangle align="client" color="#1A1A2E" strokeColor="#4ECDC4" strokeSize="1" xradius="6" yradius="6"/>
                                <label align="client" text="Atributos Core" horzTextAlign="center" fontColor="#FFD700" fontSize="13" fontStyle="bold"/>
                            </layout>
                            
                            <layout align="top" height="30" margins="{top=4}">
                                <label align="left" width="180" text="Força:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="forca" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">

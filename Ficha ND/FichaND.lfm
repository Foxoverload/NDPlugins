                                <edit align="left" width="60" field="medicina" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="160" text="História:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="historia_attr" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="160" text="Ofício:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="oficio" fontColor="white" horzTextAlign="center"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="160" text="Conhecimento:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                                <edit align="left" width="60" field="conhecimento" fontColor="white" horzTextAlign="center"/>
                            </layout>

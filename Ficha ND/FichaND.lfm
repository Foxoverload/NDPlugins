                        <checkBox align="left" width="22" field="trait_politico_s2" text="" fontColor="gold" fontSize="14"/>
                        <checkBox align="left" width="22" field="trait_politico_s3" text="" fontColor="gold" fontSize="14"/>
                        <checkBox align="left" width="22" field="trait_politico_s4" text="" fontColor="gold" fontSize="14"/>
                        <checkBox align="left" width="22" field="trait_politico_s5" text="" fontColor="gold" fontSize="14"/>
                        <label align="left" width="130" text="(50 a 250 pts)" fontColor="#888888" fontSize="10" fontStyle="italic" margins="{left=5}"/>
                    </layout>

<!-- Script de calculo dos Atributos -->

                    <script>
                        local function atualizarBarras()
                            if sheet == nil then return end;
                            
                            local pvMax = tonumber(sheet.pv) or 0;
                            local pvAtual = tonumber(sheet.pv_atual) or 0;
                            local chakraMax = tonumber(sheet.pchakra) or 0;
                            local chakraAtual = tonumber(sheet.pchakra_atual) or 0;
                            local estMax = tonumber(sheet.pestamina) or 0;
                            local estAtual = tonumber(sheet.pestamina_atual) or 0;
                            
                            local fixedLabels = 300;
                            local rowW = math.max((self.rowBarraPv ~= nil and self.rowBarraPv.width or 900), 400);
                            local barraLargPv = rowW - fixedLabels;
                            local barraLargChk = barraLargPv;
                            local barraLargEst = barraLargPv;
                            
                            -- Barra PV (cor dinâmica: verde > amarelo > vermelho)
                            if pvMax > 0 and self.barraPv ~= nil then
                                local pct = math.min(pvAtual / pvMax, 1);
                                self.barraPv.width = math.floor(pct * barraLargPv);
                                if pct > 0.6 then
                                    self.barraPv.color = "#22CC55";
                                elseif pct > 0.3 then
                                    self.barraPv.color = "#DDAA22";
                                else
                                    self.barraPv.color = "#CC2222";
                                end
                            end
                            
                            -- Barra Chakra (cor dinâmica: azul > amarelo > vermelho)
                            if chakraMax > 0 and self.barraChakra ~= nil then
                                local pct = math.min(chakraAtual / chakraMax, 1);
                                self.barraChakra.width = math.floor(pct * barraLargChk);
                                if pct > 0.6 then
                                    self.barraChakra.color = "#3388FF";
                                elseif pct > 0.3 then
                                    self.barraChakra.color = "#DDAA22";
                                else
                                    self.barraChakra.color = "#CC2222";
                                end
                            end
                            
                            -- Barra Estamina (cor dinâmica: turquesa > amarelo > vermelho)
                            if estMax > 0 and self.barraEstamina ~= nil then
                                local pct = math.min(estAtual / estMax, 1);
                                self.barraEstamina.width = math.floor(pct * barraLargEst);
                                if pct > 0.6 then
                                    self.barraEstamina.color = "#4ECDC4";
                                elseif pct > 0.3 then
                                    self.barraEstamina.color = "#DDAA22";
                                else
                                    self.barraEstamina.color = "#CC2222";
                                end
                            end
                        end
                        
                        local function validarInterpretativos()
                            if sheet == nil then return end;
                            
                            local campos = {'sobrevivencia','armadilha','empatia','intimidacao','ladinagem','enganacao','percepcao','persuasao','seducao','medicina','historia_attr','oficio','conhecimento','aprendizado','ensinamento'};
                            local valores = {};
                            
                            for i, campo in ipairs(campos) do
                                valores[i] = tonumber(sheet[campo]) or 0;
                            end
                            
                            -- Ordenar cópia para descobrir ranking
                            local ordenado = {};
                            for i, v in ipairs(valores) do
                                ordenado[i] = {idx = i, val = v};
                            end
                            table.sort(ordenado, function(a, b) return a.val > b.val end);
                            
                            -- Aplicar caps: 1o pode ser 10, 2o e 3o podem ser 8, demais max 7
                            local caps = {};
                            for i = 1, #ordenado do
                                if i == 1 then
                                    caps[ordenado[i].idx] = 10;
                                elseif not (i > 3) then
                                    caps[ordenado[i].idx] = 8;
                                else
                                    caps[ordenado[i].idx] = 7;
                                end
                            end
                            
                            local corrigido = false;
                            for i, campo in ipairs(campos) do
                                local val = valores[i];
                                local cap = caps[i];
                                if val > cap then
                                    sheet[campo] = tostring(cap);
                                    valores[i] = cap;
                                    corrigido = true;
                                end
                            end
                            
                            if corrigido then
                                sheet.aviso_interp = "⚠ Valor corrigido! (max: 1×10, 2×8, demais 7)";
                            else
                                sheet.aviso_interp = "";
                            end
                            
                            return valores;
                        end
                        
                        local function contarPontosJutsu()
                            if sheet == nil then return end;
                            
                            local edits = {self.edtTecTaijutsu, self.edtTecBukijutsu, self.edtTecNinjutsu, self.edtTecElemental, self.edtTecFuinjutsu, self.edtTecKuchiyose, self.edtTecKekkei, self.edtTecGerais};
                            local totalPontos = 0;
                            
                            for _, edt in ipairs(edits) do
                                if edt ~= nil then
                                    local texto = edt:getText() or "";
                                    
                                    -- Separar em linhas e procurar "Rank" em cada uma
                                    for linha in string.gmatch(texto, "[^\r\n]+") do
                                        local upper = string.upper(linha);
                                        
                                        -- Pular linhas com Gratuito
                                        if not string.find(upper, "GRATUITO") then
                                            -- Procurar "RANK" seguido de separador e letra
                                            local rankMatch = string.match(upper, "RANK[:%s]*(%S+)");
                                            if rankMatch ~= nil then
                                                if rankMatch == "SSS" or rankMatch == "MSS+" then
                                                    totalPontos = totalPontos + 400;
                                                elseif rankMatch == "SS+" then
                                                    totalPontos = totalPontos + 350;
                                                elseif rankMatch == "SS" then
                                                    totalPontos = totalPontos + 300;
                                                elseif rankMatch == "S" then
                                                    totalPontos = totalPontos + 250;
                                                elseif rankMatch == "A" then
                                                    totalPontos = totalPontos + 200;
                                                elseif rankMatch == "B" then
                                                    totalPontos = totalPontos + 150;
                                                elseif rankMatch == "C" then
                                                    totalPontos = totalPontos + 100;
                                                elseif rankMatch == "D" then
                                                    totalPontos = totalPontos + 50;
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                            
                            local nivel = tonumber(sheet.nivel) or 0;
                            local maxPontos = nivel * 100;
                            
                            sheet.jutsu_pontos_atual = tostring(totalPontos);
                            sheet.jutsu_pontos_max = tostring(maxPontos);
                            
                            local debugRanks = "";
                            if totalPontos > maxPontos then
                                sheet.jutsu_status = "Excedido em " .. (totalPontos - maxPontos) .. " pts!";
                            else
                                sheet.jutsu_status = "Restam " .. (maxPontos - totalPontos) .. " pts";
                            end
                        end
                        
                        local function calcularAtributos()
                            if sheet == nil then return end;
                            
                            -- Ler atributos core
                            local forca = tonumber(sheet.forca) or 0;
                            local agilidade = tonumber(sheet.agilidade) or 0;
                            local constituicao = tonumber(sheet.constituicao) or 0;
                            local destreza = tonumber(sheet.destreza) or 0;
                            local ctrl_chakra = tonumber(sheet.ctrl_chakra) or 0;
                            local concentracao = tonumber(sheet.concentracao) or 0;
                            local forca_espiritual = tonumber(sheet.forca_espiritual) or 0;
                            local inteligencia = tonumber(sheet.inteligencia) or 0;
                            
                            -- Bônus de status: combina multiplier do texto + seleção dos comboboxes
                            local pctPv       = (tonumber(sheet.bonus_pv) or 0) + (tonumber(sheet.trait_pv) or 0);
                            local pctChakra   = (tonumber(sheet.bonus_pchakra) or 0) + (tonumber(sheet.trait_pchakra) or 0);
                            local pctEstamina = (tonumber(sheet.bonus_pestamina) or 0) + (tonumber(sheet.trait_pestamina) or 0);
                            local multPv       = 1 + pctPv / 100;
                            local multChakra   = 1 + pctChakra / 100;
                            local multEstamina = 1 + pctEstamina / 100;
                            
                            -- Contador de pontos Core
                            local totalCore = forca + agilidade + constituicao + destreza + ctrl_chakra + concentracao + forca_espiritual + inteligencia;
                            sheet.pontos_core_resumo = "Pontos Core: " .. totalCore;
                            sheet.limite_atributo = tostring(math.floor(totalCore / 8) + 3);
                            sheet.nivel = tostring(math.floor(totalCore / 2) - 7);
                            
                            -- Validar e contar pontos Interpretativos
                            local interpVals = validarInterpretativos();
                            local totalInterp = 0;
                            if interpVals ~= nil then
                                for i = 1, #interpVals do
                                    totalInterp = totalInterp + interpVals[i];
                                end
                            end
                            local maxInterp = tonumber(sheet.max_pontos_interp) or 0;
                            sheet.pontos_interp_resumo = "Pontos Interp.: " .. totalInterp .. " / " .. maxInterp;
                            sheet.interp_uso_resumo = totalInterp .. " / " .. maxInterp;
                            
                            -- Pontos de Vida / Chakra / Estamina (com multiplicadores de bônus %)
                            sheet.pv       = tostring(math.floor((constituicao + forca) * 45 * multPv));
                            sheet.pchakra  = tostring(math.floor((ctrl_chakra + forca_espiritual + inteligencia) * 34 * multChakra));
                            sheet.pestamina= tostring(math.floor((agilidade + destreza + concentracao) * 34 * multEstamina));
                            
                            -- Atualizar barras visuais
                            atualizarBarras();
                            
                            -- Atributos de Combate
                            local taijutsu = math.floor(forca + agilidade * 0.5);
                            local bukijutsu = math.floor(destreza + forca * 0.5);
                            local ninjutsu = math.floor(forca_espiritual + ctrl_chakra * 0.5);
                            local genjutsu = math.floor(ctrl_chakra + inteligencia * 0.5);
                            local genjutsu_kai = math.floor((inteligencia + ctrl_chakra + concentracao) / 2);
                            local fuinjutsu = math.floor(inteligencia + forca_espiritual * 0.5);
                            local arremesso = math.floor(concentracao + destreza * 0.5);
                            local esquiva = math.floor((agilidade + concentracao + inteligencia + constituicao) / 2.5);
                            local bloqueio_fisico = math.floor((forca + destreza + constituicao + agilidade) / 2.5);
                            local bloqueio_chakra = math.floor((ctrl_chakra + forca_espiritual + constituicao + concentracao) / 2.5);
                            local reflexo = math.floor((concentracao + agilidade + constituicao + inteligencia) / 2.5);
                            local iniciativa = math.floor((forca + destreza + concentracao + agilidade) / 2.5);
                            
                            -- Sharingan / Kekkei Genkai bonus
                            local kkg_bonus = 0;
                            local kkg_nome = "";
                            if tostring(sheet.kkg_sharingan3) == "true" then
                                kkg_bonus = 4; kkg_nome = "Sharingan 3 Estagio ativo";
                            elseif tostring(sheet.kkg_sharingan2) == "true" then
                                kkg_bonus = 3; kkg_nome = "Sharingan 2 Estagio ativo";
                            elseif tostring(sheet.kkg_sharingan1) == "true" then
                                kkg_bonus = 2; kkg_nome = "Sharingan 1 Estagio ativo";
                            end
                            sheet.kkg_ativos_label = kkg_nome;
                            
                            -- Trait de Combate: dropdown + 5 estrelas
                            local n_tc = 0;
                            if tostring(sheet.trait_combate_s1) == 'true' then n_tc = n_tc + 1; end
                            if tostring(sheet.trait_combate_s2) == 'true' then n_tc = n_tc + 1; end
                            if tostring(sheet.trait_combate_s3) == 'true' then n_tc = n_tc + 1; end
                            if tostring(sheet.trait_combate_s4) == 'true' then n_tc = n_tc + 1; end
                            if tostring(sheet.trait_combate_s5) == 'true' then n_tc = n_tc + 1; end
                            local tc_tipo = tostring(sheet.trait_combate_tipo) or 'nenhum';
                            local t_artmarcial = 0; local t_domarmas = 0; local t_manipchakra = 0;
                            local t_ilusionista = 0; local t_menteblind = 0; local t_bloqueador = 0; local t_intuicao = 0;
                            if n_tc > 0 then
                                if tc_tipo == 'artmarcial' then t_artmarcial = 2 + (n_tc - 1);
                                elseif tc_tipo == 'domarmas' then t_domarmas = 2 + (n_tc - 1);
                                elseif tc_tipo == 'manipchakra' then t_manipchakra = 2 + (n_tc - 1);
                                elseif tc_tipo == 'ilusionista' then t_ilusionista = 2 + (n_tc - 1);
                                elseif tc_tipo == 'menteblind' then t_menteblind = 4 + (n_tc - 1);
                                elseif tc_tipo == 'bloqueador' then t_bloqueador = 1 + (n_tc - 1);
                                elseif tc_tipo == 'intuicao' then t_intuicao = 2 + (n_tc - 1);
                                end
                            end
                            
                            sheet.taijutsu = tostring(taijutsu + (tonumber(sheet.bonus_taijutsu) or 0) + kkg_bonus + t_artmarcial);
                            sheet.bukijutsu = tostring(bukijutsu + (tonumber(sheet.bonus_bukijutsu) or 0) + kkg_bonus + t_domarmas);
                            sheet.ninjutsu = tostring(ninjutsu + (tonumber(sheet.bonus_ninjutsu) or 0) + kkg_bonus + t_manipchakra);
                            sheet.genjutsu = tostring(genjutsu + (tonumber(sheet.bonus_genjutsu) or 0) + kkg_bonus + t_ilusionista);
                            sheet.genjutsu_kai = tostring(genjutsu_kai + (tonumber(sheet.bonus_genjutsu_kai) or 0) + kkg_bonus + t_ilusionista + t_menteblind);
                            sheet.fuinjutsu = tostring(fuinjutsu + (tonumber(sheet.bonus_fuinjutsu) or 0) + t_manipchakra);
                            sheet.arremesso = tostring(arremesso + (tonumber(sheet.bonus_arremesso) or 0) + kkg_bonus + t_domarmas);
                            sheet.esquiva = tostring(esquiva + (tonumber(sheet.bonus_esquiva) or 0) + kkg_bonus + t_intuicao);
                            sheet.bloqueio_fisico = tostring(bloqueio_fisico + (tonumber(sheet.bonus_bloqueio_fisico) or 0) + kkg_bonus + t_bloqueador);
                            sheet.bloqueio_chakra = tostring(bloqueio_chakra + (tonumber(sheet.bonus_bloqueio_chakra) or 0) + kkg_bonus + t_bloqueador);
                            sheet.reflexo = tostring(reflexo + (tonumber(sheet.bonus_reflexo) or 0) + t_intuicao);
                            sheet.iniciativa = tostring(iniciativa + (tonumber(sheet.bonus_iniciativa) or 0) + t_intuicao);
                            
                            -- Atributos de Combate Únicos (com bônus flat + traits)
                            sheet.tai_bukijutsu = tostring(math.floor((taijutsu + bukijutsu) / 2) + (tonumber(sheet.bonus_tai_bukijutsu) or 0) + t_artmarcial + t_domarmas);
                            sheet.nin_taijutsu = tostring(math.floor((taijutsu + ninjutsu) / 2) + (tonumber(sheet.bonus_nin_taijutsu) or 0) + t_artmarcial + t_manipchakra);
                            sheet.hiraishin = tostring(math.floor((ninjutsu + fuinjutsu) / 2) + (tonumber(sheet.bonus_hiraishin) or 0));
                            sheet.movimentacao = tostring(math.floor(agilidade + inteligencia / 2) + (tonumber(sheet.bonus_movimentacao) or 0) + t_intuicao);
                            
                            contarPontosJutsu();
                        end
                    </script>
                    
                    <!-- Gatilho: recalcular quando qualquer atributo core ou interpretativo muda -->
                    <dataLink fields="{'forca', 'agilidade', 'constituicao', 'destreza', 'ctrl_chakra', 'concentracao', 'forca_espiritual', 'inteligencia', 'sobrevivencia', 'armadilha', 'empatia', 'intimidacao', 'ladinagem', 'enganacao', 'percepcao', 'persuasao', 'seducao', 'medicina', 'historia_attr', 'oficio', 'conhecimento', 'aprendizado', 'ensinamento', 'trait_pv', 'trait_pchakra', 'trait_pestamina', 'trait_combate_tipo', 'trait_combate_s1', 'trait_combate_s2', 'trait_combate_s3', 'trait_combate_s4', 'trait_combate_s5', 'trait_olfato_s1','trait_olfato_s2','trait_olfato_s3','trait_olfato_s4','trait_olfato_s5', 'trait_aparencia_s1','trait_aparencia_s2','trait_aparencia_s3','trait_aparencia_s4','trait_aparencia_s5', 'trait_erudito_s1','trait_erudito_s2','trait_erudito_s3','trait_erudito_s4','trait_erudito_s5', 'trait_sobrevivente_s1','trait_sobrevivente_s2','trait_sobrevivente_s3','trait_sobrevivente_s4','trait_sobrevivente_s5', 'trait_mednin_s1','trait_mednin_s2','trait_mednin_s3','trait_mednin_s4','trait_mednin_s5', 'trait_manipulador_s1','trait_manipulador_s2','trait_manipulador_s3','trait_manipulador_s4','trait_manipulador_s5', 'trait_cacador_s1','trait_cacador_s2','trait_cacador_s3','trait_cacador_s4','trait_cacador_s5', 'trait_politico_s1','trait_politico_s2','trait_politico_s3','trait_politico_s4','trait_politico_s5'}">
                        <event name="onChange">
                            calcularAtributos();
                        </event>
                    </dataLink>
                    
                    <!-- Gatilho: recalcular quando Kekkei Genkai muda -->
                    <dataLink fields="{'kkg_sharingan1', 'kkg_sharingan2', 'kkg_sharingan3'}">
                        <event name="onChange">
                            calcularAtributos();
                        </event>
                    </dataLink>
                    
                    <!-- Gatilho: atualizar barras quando PV/Chakra/Estamina atuais mudam -->
                    <dataLink fields="{'pv_atual', 'pchakra_atual', 'pestamina_atual', 'pv', 'pchakra', 'pestamina'}">
                        <event name="onChange">
                            atualizarBarras();
                        </event>
                    </dataLink>
                    
                </layout>
            </scrollBox>
        </tab>
        
        <tab title="Técnicas">
            <layout align="top" height="32" margins="{left=10, right=10, top=4, bottom=2}">
                <rectangle align="client" color="#141428" strokeColor="#4488FF" strokeSize="1" xradius="8" yradius="8"/>
                <label align="left" width="140" text="  Pontos de Jutsu:" fontColor="#4488FF" fontSize="12" fontStyle="bold" horzTextAlign="leading"/>
                <label name="lblJutsuPontosAtual" align="left" width="60" field="jutsu_pontos_atual" fontColor="#FFD700" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                <label align="left" width="20" text=" / " fontColor="#AAAAAA" fontSize="12" horzTextAlign="center"/>
                <label name="lblJutsuPontosMax" align="left" width="60" field="jutsu_pontos_max" fontColor="#88FF88" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                <label name="lblJutsuStatus" align="client" field="jutsu_status" fontColor="#FF6666" fontSize="11" fontStyle="italic" horzTextAlign="leading" margins="{left=10}"/>
            </layout>
            <tabControl align="client">
                <tab title="Taijutsu">
                    <richEdit name="edtTecTaijutsu" align="client" field="tec_taijutsu" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Bukijutsu">
                    <richEdit name="edtTecBukijutsu" align="client" field="tec_bukijutsu" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Ninjutsu">
                    <richEdit name="edtTecNinjutsu" align="client" field="tec_ninjutsu" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Elemental">
                    <richEdit name="edtTecElemental" align="client" field="tec_elemental" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Fuinjutsu">
                    <richEdit name="edtTecFuinjutsu" align="client" field="tec_fuinjutsu" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Kuchiyose">
                    <richEdit name="edtTecKuchiyose" align="client" field="tec_kuchiyose" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Kekkei Genkai">
                    <richEdit name="edtTecKekkei" align="client" field="tec_kekkei_genkai" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Hab. Gerais">
                    <richEdit name="edtTecGerais" align="client" field="tec_habilidades_gerais" backgroundColor="#1A1A1A" defaultFontSize="13" defaultFontColor="white" hideSelection="false" animateImages="true"/>
                </tab>
                <tab title="Ficha de Kuchiyose">
                    <scrollBox align="client">
                        <layout align="top" height="3200" margins="{left=20, right=20, top=10}">

                    <!-- Cabeçalho -->
                    <layout align="top" height="34" margins="{top=5, bottom=6}">
                        <rectangle align="client" color="#141428" strokeColor="#FF6B35" strokeSize="2" xradius="8" yradius="8"/>
                        <label align="client" text="Ficha de Kuchiyose (Invocação)" horzTextAlign="center" fontStyle="bold" fontColor="#FF6B35" fontSize="15"/>
                    </layout>

                    <!-- Info Basica -->
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Nome:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="kuchi_nome" fontColor="white" textPrompt="Nome da Invocação"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Espécie:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="kuchi_especie" fontColor="white" textPrompt="Ex: Sapo, Cobra, Tartaruga..."/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Rank da Invocação:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="200">
                            <comboBox align="client" name="cbKuchiRank" hitTest="false" field="kuchi_rank" items="{'D (-5)','C (-4)','B (-4)','A (-3)','S (-2)','SS (-1)','SS+ (0)'}" values="{'-5','-4','-4b','-3','-2','-1','0'}" fontColor="white"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cbKuchiRank:dropDown();</event></layout>
                        </layout>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Descrição:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="kuchi_descricao" fontColor="white" textPrompt="Breve descrição da invocação"/>
                    </layout>

                    <!-- Atributos Core -->
                    <layout align="top" height="34" margins="{top=18, bottom=6}">
                        <rectangle align="client" color="#141428" strokeColor="#FF6B35" strokeSize="2" xradius="8" yradius="8"/>
                        <label align="client" text="Atributos Core" horzTextAlign="center" fontStyle="bold" fontColor="#FF6B35" fontSize="15"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Força:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_forca" fontColor="white" horzTextAlign="center"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Agilidade:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_agilidade" fontColor="white" horzTextAlign="center"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Constituição:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_constituicao" fontColor="white" horzTextAlign="center"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Destreza:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_destreza" fontColor="white" horzTextAlign="center"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Ctrl. Chakra:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_ctrl_chakra" fontColor="white" horzTextAlign="center"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Concentração:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_concentracao" fontColor="white" horzTextAlign="center"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Força Espiritual:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_forca_espiritual" fontColor="white" horzTextAlign="center"/>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Inteligência:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="60" field="kuchi_inteligencia" fontColor="white" horzTextAlign="center"/>
                    </layout>

                    <!-- PV / Chakra / Estamina -->
                    <layout align="top" height="34" margins="{top=18, bottom=6}">
                        <rectangle align="client" color="#141428" strokeColor="#FF6B35" strokeSize="2" xradius="8" yradius="8"/>
                        <label align="client" text="Pontos Vitais" horzTextAlign="center" fontStyle="bold" fontColor="#FF6B35" fontSize="15"/>
                    </layout>

                    <layout name="kuchi_rowBarraPv" align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Pontos de Vida:" horzTextAlign="trailing" margins="{right=10}" fontColor="#FF6666" fontSize="13" fontStyle="bold"/>
                        <edit align="left" width="55" field="kuchi_pv_atual" fontColor="white" horzTextAlign="center"/>
                        <label align="left" width="20" text=" / " fontColor="#AAAAAA" fontSize="13" horzTextAlign="center"/>

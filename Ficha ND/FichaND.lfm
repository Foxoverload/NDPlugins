                        <label align="left" width="160" text="Pontos de Chakra:" horzTextAlign="trailing" margins="{right=10}" fontColor="#6699FF" fontSize="13" fontStyle="bold"/>
                        <edit align="left" width="55" field="kuchi_pchakra_atual" fontColor="white" horzTextAlign="center"/>
                        <label align="left" width="20" text=" / " fontColor="#AAAAAA" fontSize="13" horzTextAlign="center"/>
                        <label align="left" width="55" field="kuchi_pchakra" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                        <layout align="left" width="10" height="30"/>
                        <layout name="kuchi_containerBarraChakra" align="client" height="30" margins="{top=5, bottom=5}">
                            <rectangle name="kuchi_barraChakraFundo" align="client" color="#0A0E1A" strokeColor="#111133" strokeSize="1" xradius="6" yradius="6"/>

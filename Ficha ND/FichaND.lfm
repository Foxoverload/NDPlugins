                        </layout>
                    </layout>
                    
                    <!-- Atributos de Combate (esquerda) + Únicos (direita) -->
                    <layout align="top" height="480" margins="{top=10}">
                        
                        <!-- === COLUNA ESQUERDA: Atributos de Combate === -->
                        <layout left="0" top="0" width="530" height="480">
                            <layout align="top" height="25">
                                <rectangle align="client" color="#1A1A2E" strokeColor="#4ECDC4" strokeSize="1" xradius="6" yradius="6"/>
                                <label align="client" text="Atributos de Combate" horzTextAlign="center" fontColor="#FF8844" fontSize="13" fontStyle="bold"/>
                            </layout>
                            
                            <layout align="top" height="30" margins="{top=4}">
                                <label align="left" width="155" text="Taijutsu:" horzTextAlign="trailing" margins="{right=8}" fontColor="#B8B8CC" fontSize="13"/>
                                <label align="left" width="45" field="taijutsu" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                                <button align="left" width="28" height="22" text="[d]" fontSize="10" margins="{right=4}">
                                    <event name="onClick">local _expr = "1d20 + " .. (tonumber(sheet.taijutsu) or 0); local _mesa = Firecast.getMesaDe(sheet); if _mesa then _mesa.chat:rolarDados(Firecast.interpretarRolagem(_expr), "Taijutsu"); end;</event>
                                </button>
                                <label align="client" text="(Forca + 50% Agilidade)" fontColor="#888888" fontSize="10" fontStyle="italic"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="155" text="Bukijutsu:" horzTextAlign="trailing" margins="{right=8}" fontColor="#B8B8CC" fontSize="13"/>
                                <label align="left" width="45" field="bukijutsu" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                                <button align="left" width="28" height="22" text="[d]" fontSize="10" margins="{right=4}">
                                    <event name="onClick">local _expr = "1d20 + " .. (tonumber(sheet.bukijutsu) or 0); local _mesa = Firecast.getMesaDe(sheet); if _mesa then _mesa.chat:rolarDados(Firecast.interpretarRolagem(_expr), "Bukijutsu"); end;</event>
                                </button>
                                <label align="client" text="(Destreza + 50% Forca)" fontColor="#888888" fontSize="10" fontStyle="italic"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="155" text="Ninjutsu:" horzTextAlign="trailing" margins="{right=8}" fontColor="#B8B8CC" fontSize="13"/>
                                <label align="left" width="45" field="ninjutsu" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                                <button align="left" width="28" height="22" text="[d]" fontSize="10" margins="{right=4}">
                                    <event name="onClick">local _expr = "1d20 + " .. (tonumber(sheet.ninjutsu) or 0); local _mesa = Firecast.getMesaDe(sheet); if _mesa then _mesa.chat:rolarDados(Firecast.interpretarRolagem(_expr), "Ninjutsu"); end;</event>
                                </button>
                                <label align="client" text="(F. Espiritual + 50% Ctrl Chakra)" fontColor="#888888" fontSize="10" fontStyle="italic"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">
                                <label align="left" width="155" text="Genjutsu:" horzTextAlign="trailing" margins="{right=8}" fontColor="#B8B8CC" fontSize="13"/>
                                <label align="left" width="45" field="genjutsu" fontColor="white" fontSize="13" fontStyle="bold" horzTextAlign="center"/>
                                <button align="left" width="28" height="22" text="[d]" fontSize="10" margins="{right=4}">
                                    <event name="onClick">local _expr = "1d20 + " .. (tonumber(sheet.genjutsu) or 0); local _mesa = Firecast.getMesaDe(sheet); if _mesa then _mesa.chat:rolarDados(Firecast.interpretarRolagem(_expr), "Genjutsu"); end;</event>
                                </button>
                                <label align="client" text="(Ctrl Chakra + 50% Inteligencia)" fontColor="#888888" fontSize="10" fontStyle="italic"/>
                            </layout>
                            <layout align="top" height="30" margins="{top=2}">

                    <!-- Script de cálculo do Kuchiyose -->
                    <script>
                        local function kuchi_atualizarBarras()
                            if sheet == nil then return end;
                            local pvMax = tonumber(sheet.kuchi_pv) or 0;
                            local pvAtual = tonumber(sheet.kuchi_pv_atual) or 0;
                            local chakraMax = tonumber(sheet.kuchi_pchakra) or 0;
                            local chakraAtual = tonumber(sheet.kuchi_pchakra_atual) or 0;
                            local estMax = tonumber(sheet.kuchi_pestamina) or 0;
                            local estAtual = tonumber(sheet.kuchi_pestamina_atual) or 0;

                            local fixedLabels = 300;
                            local rowW = math.max((self.kuchi_rowBarraPv ~= nil and self.kuchi_rowBarraPv.width or 900), 400);
                            local barraLarg = rowW - fixedLabels;

                            if pvMax > 0 and self.kuchi_barraPv ~= nil then
                                local pct = math.min(pvAtual / pvMax, 1);
                                self.kuchi_barraPv.width = math.floor(pct * barraLarg);
                                if pct > 0.6 then self.kuchi_barraPv.color = "#22CC55";
                                elseif pct > 0.3 then self.kuchi_barraPv.color = "#DDAA22";
                                else self.kuchi_barraPv.color = "#CC2222"; end
                            end
                            if chakraMax > 0 and self.kuchi_barraChakra ~= nil then
                                local pct = math.min(chakraAtual / chakraMax, 1);
                                self.kuchi_barraChakra.width = math.floor(pct * barraLarg);
                                if pct > 0.6 then self.kuchi_barraChakra.color = "#3388FF";
                                elseif pct > 0.3 then self.kuchi_barraChakra.color = "#DDAA22";
                                else self.kuchi_barraChakra.color = "#CC2222"; end
                            end
                            if estMax > 0 and self.kuchi_barraEstamina ~= nil then
                                local pct = math.min(estAtual / estMax, 1);
                                self.kuchi_barraEstamina.width = math.floor(pct * barraLarg);
                                if pct > 0.6 then self.kuchi_barraEstamina.color = "#22CC55";
                                elseif pct > 0.3 then self.kuchi_barraEstamina.color = "#DDAA22";
                                else self.kuchi_barraEstamina.color = "#CC2222"; end
                            end
                        end

                        local function calcularKuchiyose()
                            if sheet == nil then return end;
                            local forca = tonumber(sheet.kuchi_forca) or 0;
                            local agilidade = tonumber(sheet.kuchi_agilidade) or 0;
                            local constituicao = tonumber(sheet.kuchi_constituicao) or 0;
                            local destreza = tonumber(sheet.kuchi_destreza) or 0;
                            local ctrl_chakra = tonumber(sheet.kuchi_ctrl_chakra) or 0;
                            local concentracao = tonumber(sheet.kuchi_concentracao) or 0;
                            local forca_espiritual = tonumber(sheet.kuchi_forca_espiritual) or 0;
                            local inteligencia = tonumber(sheet.kuchi_inteligencia) or 0;

                            -- PV / Chakra / Estamina
                            local pvBase = math.floor((constituicao * 10) + (forca * 5));
                            local chakraBase = math.floor((ctrl_chakra * 10) + (forca_espiritual * 5));
                            local estBase = math.floor((constituicao * 5) + (agilidade * 5) + (forca * 2));
                            sheet.kuchi_pv = tostring(pvBase);
                            sheet.kuchi_pchakra = tostring(chakraBase);
                            sheet.kuchi_pestamina = tostring(estBase);
                            kuchi_atualizarBarras();

                            -- Rank penalty
                            local rankVal = tostring(sheet.kuchi_rank);
                            local penalty = -5;
                            if rankVal == '-5' then penalty = -5;
                            elseif rankVal == '-4' or rankVal == '-4b' then penalty = -4;
                            elseif rankVal == '-3' then penalty = -3;
                            elseif rankVal == '-2' then penalty = -2;
                            elseif rankVal == '-1' then penalty = -1;
                            elseif rankVal == '0' then penalty = 0;
                            end

                            if self.kuchi_rank_penalty_label ~= nil then
                                if penalty == 0 then
                                    self.kuchi_rank_penalty_label.text = "Rank SS+: Sem penalidade";
                                else
                                    self.kuchi_rank_penalty_label.text = "Penalidade de Rank: " .. tostring(penalty) .. " em todos os atributos de combate";
                                end
                            end

                            -- Atributos de Combate + penalty + traits
                            local n_am = 0;
                            if tostring(sheet.kuchi_trait_artmarcial_s1) == 'true' then n_am = n_am + 1; end
                            if tostring(sheet.kuchi_trait_artmarcial_s2) == 'true' then n_am = n_am + 1; end
                            if tostring(sheet.kuchi_trait_artmarcial_s3) == 'true' then n_am = n_am + 1; end
                            if tostring(sheet.kuchi_trait_artmarcial_s4) == 'true' then n_am = n_am + 1; end
                            if tostring(sheet.kuchi_trait_artmarcial_s5) == 'true' then n_am = n_am + 1; end
                            if tostring(sheet.kuchi_trait_artmarcial_s6) == 'true' then n_am = n_am + 1; end
                            local t_artmarcial = 0; if n_am > 0 then t_artmarcial = 2 + (n_am - 1); end

                            local n_da = 0;
                            if tostring(sheet.kuchi_trait_domarmas_s1) == 'true' then n_da = n_da + 1; end
                            if tostring(sheet.kuchi_trait_domarmas_s2) == 'true' then n_da = n_da + 1; end
                            if tostring(sheet.kuchi_trait_domarmas_s3) == 'true' then n_da = n_da + 1; end
                            if tostring(sheet.kuchi_trait_domarmas_s4) == 'true' then n_da = n_da + 1; end
                            if tostring(sheet.kuchi_trait_domarmas_s5) == 'true' then n_da = n_da + 1; end
                            if tostring(sheet.kuchi_trait_domarmas_s6) == 'true' then n_da = n_da + 1; end
                            local t_domarmas = 0; if n_da > 0 then t_domarmas = 2 + (n_da - 1); end

                            local n_mc = 0;
                            if tostring(sheet.kuchi_trait_manipchakra_s1) == 'true' then n_mc = n_mc + 1; end
                            if tostring(sheet.kuchi_trait_manipchakra_s2) == 'true' then n_mc = n_mc + 1; end
                            if tostring(sheet.kuchi_trait_manipchakra_s3) == 'true' then n_mc = n_mc + 1; end
                            if tostring(sheet.kuchi_trait_manipchakra_s4) == 'true' then n_mc = n_mc + 1; end
                            if tostring(sheet.kuchi_trait_manipchakra_s5) == 'true' then n_mc = n_mc + 1; end
                            if tostring(sheet.kuchi_trait_manipchakra_s6) == 'true' then n_mc = n_mc + 1; end
                            local t_manipchakra = 0; if n_mc > 0 then t_manipchakra = 2 + (n_mc - 1); end

                            local n_il = 0;
                            if tostring(sheet.kuchi_trait_ilusionista_s1) == 'true' then n_il = n_il + 1; end
                            if tostring(sheet.kuchi_trait_ilusionista_s2) == 'true' then n_il = n_il + 1; end
                            if tostring(sheet.kuchi_trait_ilusionista_s3) == 'true' then n_il = n_il + 1; end
                            if tostring(sheet.kuchi_trait_ilusionista_s4) == 'true' then n_il = n_il + 1; end
                            if tostring(sheet.kuchi_trait_ilusionista_s5) == 'true' then n_il = n_il + 1; end
                            if tostring(sheet.kuchi_trait_ilusionista_s6) == 'true' then n_il = n_il + 1; end
                            local t_ilusionista = 0; if n_il > 0 then t_ilusionista = 2 + (n_il - 1); end

                            local n_mb = 0;
                            if tostring(sheet.kuchi_trait_menteblind_s1) == 'true' then n_mb = n_mb + 1; end
                            if tostring(sheet.kuchi_trait_menteblind_s2) == 'true' then n_mb = n_mb + 1; end
                            if tostring(sheet.kuchi_trait_menteblind_s3) == 'true' then n_mb = n_mb + 1; end
                            if tostring(sheet.kuchi_trait_menteblind_s4) == 'true' then n_mb = n_mb + 1; end
                            if tostring(sheet.kuchi_trait_menteblind_s5) == 'true' then n_mb = n_mb + 1; end
                            if tostring(sheet.kuchi_trait_menteblind_s6) == 'true' then n_mb = n_mb + 1; end
                            local t_menteblind = 0; if n_mb > 0 then t_menteblind = 4 + (n_mb - 1); end

                            local n_bl = 0;
                            if tostring(sheet.kuchi_trait_bloqueador_s1) == 'true' then n_bl = n_bl + 1; end
                            if tostring(sheet.kuchi_trait_bloqueador_s2) == 'true' then n_bl = n_bl + 1; end
                            if tostring(sheet.kuchi_trait_bloqueador_s3) == 'true' then n_bl = n_bl + 1; end
                            if tostring(sheet.kuchi_trait_bloqueador_s4) == 'true' then n_bl = n_bl + 1; end
                            if tostring(sheet.kuchi_trait_bloqueador_s5) == 'true' then n_bl = n_bl + 1; end
                            if tostring(sheet.kuchi_trait_bloqueador_s6) == 'true' then n_bl = n_bl + 1; end
                            local t_bloqueador = 0; if n_bl > 0 then t_bloqueador = 1 + (n_bl - 1); end

                            local n_in = 0;
                            if tostring(sheet.kuchi_trait_intuicao_s1) == 'true' then n_in = n_in + 1; end
                            if tostring(sheet.kuchi_trait_intuicao_s2) == 'true' then n_in = n_in + 1; end
                            if tostring(sheet.kuchi_trait_intuicao_s3) == 'true' then n_in = n_in + 1; end
                            if tostring(sheet.kuchi_trait_intuicao_s4) == 'true' then n_in = n_in + 1; end
                            if tostring(sheet.kuchi_trait_intuicao_s5) == 'true' then n_in = n_in + 1; end
                            if tostring(sheet.kuchi_trait_intuicao_s6) == 'true' then n_in = n_in + 1; end
                            local t_intuicao = 0; if n_in > 0 then t_intuicao = 2 + (n_in - 1); end

                            local taijutsu = math.floor(forca + agilidade * 0.5) + penalty;
                            local bukijutsu = math.floor(destreza + forca * 0.5) + penalty;
                            local ninjutsu = math.floor(forca_espiritual + ctrl_chakra * 0.5) + penalty;
                            local genjutsu = math.floor(ctrl_chakra + inteligencia * 0.5) + penalty;
                            local genjutsu_kai = math.floor((inteligencia + ctrl_chakra + concentracao) / 2) + penalty;
                            local fuinjutsu = math.floor(inteligencia + forca_espiritual * 0.5) + penalty;
                            local arremesso = math.floor(concentracao + destreza * 0.5) + penalty;
                            local esquiva = math.floor((agilidade + concentracao + inteligencia + constituicao) / 2.5) + penalty;
                            local bloqueio_fisico = math.floor((forca + destreza + constituicao + agilidade) / 2.5) + penalty;
                            local bloqueio_chakra = math.floor((ctrl_chakra + forca_espiritual + constituicao + concentracao) / 2.5) + penalty;
                            local reflexo = math.floor((concentracao + agilidade + constituicao + inteligencia) / 2.5) + penalty;
                            local iniciativa = math.floor((forca + destreza + concentracao + agilidade) / 2.5) + penalty;

                            sheet.kuchi_taijutsu = tostring(taijutsu + t_artmarcial + (tonumber(sheet.kuchi_bonus_taijutsu) or 0));
                            sheet.kuchi_bukijutsu = tostring(bukijutsu + t_domarmas + (tonumber(sheet.kuchi_bonus_bukijutsu) or 0));
                            sheet.kuchi_ninjutsu = tostring(ninjutsu + t_manipchakra + (tonumber(sheet.kuchi_bonus_ninjutsu) or 0));
                            sheet.kuchi_genjutsu = tostring(genjutsu + t_ilusionista + (tonumber(sheet.kuchi_bonus_genjutsu) or 0));
                            sheet.kuchi_genjutsu_kai = tostring(genjutsu_kai + t_ilusionista + t_menteblind + (tonumber(sheet.kuchi_bonus_genjutsu_kai) or 0));
                            sheet.kuchi_fuinjutsu = tostring(fuinjutsu + t_manipchakra + (tonumber(sheet.kuchi_bonus_fuinjutsu) or 0));
                            sheet.kuchi_arremesso = tostring(arremesso + t_domarmas + (tonumber(sheet.kuchi_bonus_arremesso) or 0));
                            sheet.kuchi_esquiva = tostring(esquiva + t_intuicao + (tonumber(sheet.kuchi_bonus_esquiva) or 0));
                            sheet.kuchi_bloqueio_fisico = tostring(bloqueio_fisico + t_bloqueador + (tonumber(sheet.kuchi_bonus_bloqueio_fisico) or 0));
                            sheet.kuchi_bloqueio_chakra = tostring(bloqueio_chakra + t_bloqueador + (tonumber(sheet.kuchi_bonus_bloqueio_chakra) or 0));
                            sheet.kuchi_reflexo = tostring(reflexo + t_intuicao + (tonumber(sheet.kuchi_bonus_reflexo) or 0));
                            sheet.kuchi_iniciativa = tostring(iniciativa + t_intuicao + (tonumber(sheet.kuchi_bonus_iniciativa) or 0));

                            -- Unicos
                            sheet.kuchi_tai_bukijutsu = tostring(math.floor((taijutsu + bukijutsu) / 2) + t_artmarcial + t_domarmas + (tonumber(sheet.kuchi_bonus_tai_bukijutsu) or 0));
                            sheet.kuchi_nin_taijutsu = tostring(math.floor((taijutsu + ninjutsu) / 2) + t_artmarcial + t_manipchakra + (tonumber(sheet.kuchi_bonus_nin_taijutsu) or 0));
                            sheet.kuchi_hiraishin = tostring(math.floor((ninjutsu + fuinjutsu) / 2) + (tonumber(sheet.kuchi_bonus_hiraishin) or 0));
                            sheet.kuchi_movimentacao = tostring(math.floor(agilidade + inteligencia / 2) + penalty + t_intuicao + (tonumber(sheet.kuchi_bonus_movimentacao) or 0));
                        end
                    </script>

                    <dataLink fields="{'kuchi_forca', 'kuchi_agilidade', 'kuchi_constituicao', 'kuchi_destreza', 'kuchi_ctrl_chakra', 'kuchi_concentracao', 'kuchi_forca_espiritual', 'kuchi_inteligencia', 'kuchi_rank', 'kuchi_trait_artmarcial_s1','kuchi_trait_artmarcial_s2','kuchi_trait_artmarcial_s3','kuchi_trait_artmarcial_s4','kuchi_trait_artmarcial_s5','kuchi_trait_artmarcial_s6', 'kuchi_trait_domarmas_s1','kuchi_trait_domarmas_s2','kuchi_trait_domarmas_s3','kuchi_trait_domarmas_s4','kuchi_trait_domarmas_s5','kuchi_trait_domarmas_s6', 'kuchi_trait_manipchakra_s1','kuchi_trait_manipchakra_s2','kuchi_trait_manipchakra_s3','kuchi_trait_manipchakra_s4','kuchi_trait_manipchakra_s5','kuchi_trait_manipchakra_s6', 'kuchi_trait_ilusionista_s1','kuchi_trait_ilusionista_s2','kuchi_trait_ilusionista_s3','kuchi_trait_ilusionista_s4','kuchi_trait_ilusionista_s5','kuchi_trait_ilusionista_s6', 'kuchi_trait_menteblind_s1','kuchi_trait_menteblind_s2','kuchi_trait_menteblind_s3','kuchi_trait_menteblind_s4','kuchi_trait_menteblind_s5','kuchi_trait_menteblind_s6', 'kuchi_trait_bloqueador_s1','kuchi_trait_bloqueador_s2','kuchi_trait_bloqueador_s3','kuchi_trait_bloqueador_s4','kuchi_trait_bloqueador_s5','kuchi_trait_bloqueador_s6', 'kuchi_trait_intuicao_s1','kuchi_trait_intuicao_s2','kuchi_trait_intuicao_s3','kuchi_trait_intuicao_s4','kuchi_trait_intuicao_s5','kuchi_trait_intuicao_s6'}">
                        <event name="onChange">
                            calcularKuchiyose();
                        </event>
                    </dataLink>

                    <dataLink fields="{'kuchi_pv_atual', 'kuchi_pchakra_atual', 'kuchi_pestamina_atual', 'kuchi_pv', 'kuchi_pchakra', 'kuchi_pestamina'}">
                        <event name="onChange">
                            kuchi_atualizarBarras();
                        </event>
                    </dataLink>
                    
                    <timer name="timerJutsu" interval="2000" enabled="true">
                        <event name="onTimer">
                            contarPontosJutsu();
                            calcularTraits();
                        </event>
                    </timer>

                        </layout>
                    </scrollBox>
                </tab>
            </tabControl>
        </tab>
        
        <tab title="Inventário">
            <scrollBox align="client">
                <richEdit name="edtInventario" align="client" field="inventario_fmt" backgroundColor="#222222" defaultFontSize="14" defaultFontColor="white" hideSelection="false" animateImages="true"/>
            </scrollBox>
        </tab>
        
        <tab title="História">
            <scrollBox align="client">
                <richEdit name="edtHistoria" align="client" field="historia_fmt" backgroundColor="#222222" defaultFontSize="14" defaultFontColor="white" hideSelection="false" animateImages="true"/>
            </scrollBox>
        </tab>
    </tabControl>
</form>



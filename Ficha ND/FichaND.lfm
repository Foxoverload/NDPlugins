<?xml version="1.0" encoding="UTF-8"?>
<form name="frmFichaNarutoDestiny" formType="sheetTemplate" dataType="br.com.rrpg.Ficha_Naruto_Destiny" title="Ficha Naruto Destiny" align="client" theme="dark">
    
    <!-- Templates para agilizar e manter o padrao -->
    <template name="cabecalho">
        <layout align="top" height="34" margins="{top=18, bottom=6}">
            <rectangle align="client" color="#141428" strokeColor="#FF6B35" strokeSize="2" xradius="8" yradius="8"/>
            <label align="client" text="$(texto)" horzTextAlign="center" fontStyle="bold" fontColor="#FF6B35" fontSize="15"/>
        </layout>
    </template>

    <template name="campo">
        <layout align="top" height="30" margins="{top=2}">
            <label align="left" width="130" text="$(texto)" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
            <edit align="client" field="$(campo)" fontColor="white" transparent="false"/>
        </layout>
    </template>
    
    <template name="blocoTexto">
        <layout align="top" height="$(altura)" margins="{top=5}">
            <textEditor align="client" field="$(campo)" fontColor="white" transparent="false"/>
        </layout>
    </template>

    <tabControl align="client">
        <tab title="Ficha Principal">
            <scrollBox align="client">
                
                <!-- Cadeado de Bloqueio da Ficha (fora do layout desabilitavel) -->
                <layout align="top" height="28" margins="{left=20, right=20, top=5, bottom=5}">
                    <rectangle align="client" color="#1A1A2E" strokeColor="#2A2A4E" strokeSize="1" xradius="6" yradius="6"/>
                    <checkBox name="chkCadeado" align="left" width="200" field="cadeado_ficha" text=" Travar Ficha" fontColor="#AAAACC" fontSize="12" margins="{left=8}"/>
                    <label name="lblCadeadoStatus" align="client" text="" fontColor="#88FF88" fontSize="11" fontStyle="italic" horzTextAlign="leading" margins="{left=5}"/>
                </layout>
                
                <script>
                    local function aplicarCadeado()
                        if sheet == nil then return end;
                        local locked = (tostring(sheet.cadeado_ficha) == "true");
                        
                        if self.layoutConteudo ~= nil then self.layoutConteudo.enabled = not locked; end
                        if self.edtTecTaijutsu ~= nil then self.edtTecTaijutsu.readOnly = locked; end
                        if self.edtTecBukijutsu ~= nil then self.edtTecBukijutsu.readOnly = locked; end
                        if self.edtTecNinjutsu ~= nil then self.edtTecNinjutsu.readOnly = locked; end
                        if self.edtTecElemental ~= nil then self.edtTecElemental.readOnly = locked; end
                        if self.edtTecFuinjutsu ~= nil then self.edtTecFuinjutsu.readOnly = locked; end
                        if self.edtTecKuchiyose ~= nil then self.edtTecKuchiyose.readOnly = locked; end
                        if self.edtTecKekkei ~= nil then self.edtTecKekkei.readOnly = locked; end
                        if self.edtTecGerais ~= nil then self.edtTecGerais.readOnly = locked; end
                        if self.edtInventario ~= nil then self.edtInventario.readOnly = locked; end
                        if self.edtHistoria ~= nil then self.edtHistoria.readOnly = locked; end
                        
                        if self.lblCadeadoStatus ~= nil then
                            if locked then
                                self.lblCadeadoStatus.text = "(Ficha travada - campos protegidos)";
                                self.lblCadeadoStatus.fontColor = "#FF6666";
                            else
                                self.lblCadeadoStatus.text = "(Ficha destravada)";
                                self.lblCadeadoStatus.fontColor = "#88FF88";
                            end
                        end
                    end
                </script>
                
                <dataLink fields="{'cadeado_ficha'}">
                    <event name="onChange">
                        aplicarCadeado();
                    </event>
                </dataLink>

                <layout name="layoutConteudo" align="top" height="4400" margins="{left=20, right=20, top=0}">

                    <cabecalho texto="Naruto Destiny" />
                    
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Nome:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="nome" fontColor="white" textPrompt="Nome do Personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Idade:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="idade" fontColor="white" textPrompt="Baseado no Rank Shinobi"/>
                    </layout>
                    
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Sexo:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="200">
                            <comboBox align="client" name="cb1" hitTest="false" field="sexo" items="{'♂ Masculino', '♀ Feminino'}" values="{'M', 'F'}" fontColor="white"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb1:dropDown();</event></layout>
                        </layout>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Aniversário:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="aniversario" fontColor="white" textPrompt="Dia/Mês/Ano (Ano é opcional)"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Nível:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <label align="left" width="60" field="nivel" fontColor="#FFD700" fontSize="15" fontStyle="bold" horzTextAlign="center"/>
                        <label align="client" text="(Core Total ÷ 2) - 7" fontColor="#666666" fontSize="10" fontStyle="italic"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Ryõ:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="left" width="120" field="ryous" fontColor="white" textPrompt="Digite o valor" horzTextAlign="center"/>
                        <label align="left" width="15" text="" />
                        <label align="client" field="ryous_fmt" fontColor="#FFD700" fontSize="13" fontStyle="bold"/>
                    </layout>
                    
                    <script>
                        local function formatarRyo()
                            if sheet == nil then return end;
                            local val = tonumber(sheet.ryous) or 0;
                            -- Formatar com separadores de milhar (virgula)
                            local s = tostring(math.floor(val));
                            local result = "";
                            local len = #s;
                            for i = 1, len do
                                if i > 1 and (len - i + 1) % 3 == 0 then
                                    result = result .. ",";
                                end
                                result = result .. s:sub(i, i);
                            end
                            sheet.ryous_fmt = result .. " R¥";
                        end
                    </script>
                    
                    <dataLink fields="{'ryous'}">
                        <event name="onChange">
                            formatarRyo();
                        </event>
                    </dataLink>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Altura:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="altura" fontColor="white" textPrompt="x,xxm de altura"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Peso:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="peso" fontColor="white" textPrompt="x,xx KG"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Gostos:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="gostos" fontColor="white" textPrompt="Descreva ou liste os gostos do personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Desgostos:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="desgostos" fontColor="white" textPrompt="Descreva ou liste as coisas que o personagem desgosta"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Hobbies:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="hobbies" fontColor="white" textPrompt="Descreva o(s) hobbie(s) do personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Sonho:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="sonho" fontColor="white" textPrompt="Descreva o(s) sonho(s) ou vontade(s) do personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Objetivo:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="objetivo" fontColor="white" textPrompt="Descreva ou liste o(s) objetivo(s) do personagem"/>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Interesse Romântico:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <edit align="client" field="interesse_romantico" fontColor="white" textPrompt="Descreva ou liste o(s) interesse(s) romantico(s) do personagem"/>
                    </layout>


                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Natureza:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="client">
                            <comboBox align="client" name="cb2" hitTest="false" field="natureza" fontColor="white" items="{'Selecione...','Amador','Arquiteto','Artista','Autocrata','Bon Vivant','Caçador de Emoções','Capitalista','Competidor','Conciliador','Conformista','Criança','Diretor','Diplomata','Esperto','Estrategista','Excêntrico','Executor','Explorador','Fanático','Filantropo','Galante','Guardião','Guru','Humanitário','Juiz','Malandro','Mártir','Masoquista','Monstro','Observador','Pedagogo','Penitente','Ranzinza','Sábio','Samaritano','Show de Horrores','Sobrevivente','Solitário','Sonhador','Tradicionalista','Valentão','Visionário'}" values="{'','Amador','Arquiteto','Artista','Autocrata','Bon Vivant','Caçador de Emoções','Capitalista','Competidor','Conciliador','Conformista','Criança','Diretor','Diplomata','Esperto','Estrategista','Excêntrico','Executor','Explorador','Fanático','Filantropo','Galante','Guardião','Guru','Humanitário','Juiz','Malandro','Mártir','Masoquista','Monstro','Observador','Pedagogo','Penitente','Ranzinza','Sábio','Samaritano','Show de Horrores','Sobrevivente','Solitário','Sonhador','Tradicionalista','Valentão','Visionário'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb2:dropDown();</event></layout>
                        </layout>
                    </layout>

                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Comportamento:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="client">
                            <comboBox align="client" name="cb3" hitTest="false" field="comportamento" fontColor="white" items="{'Selecione...','Amador','Arquiteto','Artista','Autocrata','Bon Vivant','Caçador de Emoções','Capitalista','Competidor','Conciliador','Conformista','Criança','Diretor','Diplomata','Esperto','Estrategista','Excêntrico','Executor','Explorador','Fanático','Filantropo','Galante','Guardião','Guru','Humanitário','Juiz','Malandro','Mártir','Masoquista','Monstro','Observador','Pedagogo','Penitente','Ranzinza','Sábio','Samaritano','Show de Horrores','Sobrevivente','Solitário','Sonhador','Tradicionalista','Valentão','Visionário'}" values="{'','Amador','Arquiteto','Artista','Autocrata','Bon Vivant','Caçador de Emoções','Capitalista','Competidor','Conciliador','Conformista','Criança','Diretor','Diplomata','Esperto','Estrategista','Excêntrico','Executor','Explorador','Fanático','Filantropo','Galante','Guardião','Guru','Humanitário','Juiz','Malandro','Mártir','Masoquista','Monstro','Observador','Pedagogo','Penitente','Ranzinza','Sábio','Samaritano','Show de Horrores','Sobrevivente','Solitário','Sonhador','Tradicionalista','Valentão','Visionário'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb3:dropDown();</event></layout>
                        </layout>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Qualidades:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="155">
                            <comboBox align="client" name="cb4" hitTest="false" field="qualidade1" fontColor="white" items="{'Nenhuma','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}" values="{'','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb4:dropDown();</event></layout>
                        </layout>
                        <layout align="left" width="155" margins="{left=3}">
                            <comboBox align="client" name="cb5" hitTest="false" field="qualidade2" fontColor="white" items="{'Nenhuma','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}" values="{'','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb5:dropDown();</event></layout>
                        </layout>
                        <layout align="left" width="155" margins="{left=3}">
                            <comboBox align="client" name="cb6" hitTest="false" field="qualidade3" fontColor="white" items="{'Nenhuma','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}" values="{'','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb6:dropDown();</event></layout>
                        </layout>
                        <layout align="left" width="155" margins="{left=3}">
                            <comboBox align="client" name="cb7" hitTest="false" field="qualidade4" fontColor="white" items="{'Nenhuma','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}" values="{'','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb7:dropDown();</event></layout>
                        </layout>
                        <layout align="left" width="155" margins="{left=3}">
                            <comboBox align="client" name="cb8" hitTest="false" field="qualidade5" fontColor="white" items="{'Nenhuma','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}" values="{'','Harmonia com a Natureza','Carismático','Boa Reputação','Ideal','Shinobi Exemplar','Enciclopédia Shinobi','Perseverança','Disciplinado','Educado','Protetor','Sensato','Leal','Motivador','Inabalável','Pragmatismo Sombrio'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb8:dropDown();</event></layout>
                        </layout>
                    </layout>
                    <layout align="top" height="30" margins="{top=2}">
                        <label align="left" width="160" text="Defeitos:" horzTextAlign="trailing" margins="{right=10}" fontColor="#B8B8CC" fontSize="13"/>
                        <layout align="left" width="155">
                            <comboBox align="client" name="cb9" hitTest="false" field="defeito1" fontColor="white" items="{'Nenhum','Código de Honra','Curiosidade','Hábito Detestável','Fanatismo','Pobreza','Pesadelos','Intolerância','Imprevisível','Esquecido','Esnobe','Excesso de Confiança','Timidez','Dificuldade de Fala','Sadismo ou Masoquismo','Obsessão','Vingança','Ódio','Pacifista','Má Fama','Fanfarronice','Sanguinolência','Hábito Negativo','Segredo Sombrio','Mentiroso','Covardia','Honestidade','Impulsividade','Ninja Orgulhoso','Lealdade Inabalável','Fair Play','Pervertido','Cabeça Quente','Sede de Poder'}" values="{'','Código de Honra','Curiosidade','Hábito Detestável','Fanatismo','Pobreza','Pesadelos','Intolerância','Imprevisível','Esquecido','Esnobe','Excesso de Confiança','Timidez','Dificuldade de Fala','Sadismo ou Masoquismo','Obsessão','Vingança','Ódio','Pacifista','Má Fama','Fanfarronice','Sanguinolência','Hábito Negativo','Segredo Sombrio','Mentiroso','Covardia','Honestidade','    Impulsividade','Ninja Orgulhoso','Lealdade Inabalável','Fair Play','Pervertido','Cabeça Quente','Sede de Poder'}"/>
                            <layout align="client" hitTest="true"><event name="onClick">self.cb9:dropDown();</event></layout>
                        </layout>
                        <layout align="left" width="155" margins="{left=3}">

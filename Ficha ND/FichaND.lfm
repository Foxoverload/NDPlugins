<?xml version="1.0" encoding="UTF-8"?>
<form name="frmFichaNarutoDestiny" formType="sheetTemplate" dataType="br.com.rrpg.Ficha_Naruto_Destiny" title="Ficha Naruto Destiny" align="client" theme="dark">

    <layout align="client" name="containerPrincipal">
        <!-- Fallback Message (hidden by default, shown if FCEXT fails) -->
        <layout name="fallbackError" align="client" visible="false">
            <rectangle align="client" color="#1A1A1A"/>
            <layout align="client" margins="{left=20, right=20, top=50}">
                <label align="top" height="30" text="ERRO: Firecast Script Extender (FCEXT) nao encontrado ou falha ao carregar." fontColor="#F87171" fontSize="18" fontStyle="bold" horzTextAlign="center"/>
                <label align="top" height="30" text="Esta ficha requer a instalacao do FCEXT v2.1+ para funcionar." fontColor="#A1A1AA" fontSize="14" horzTextAlign="center" margins="{top=10}"/>
                <label align="top" height="30" name="lblErroDetalhe" text="" fontColor="#EF4444" fontSize="12" horzTextAlign="center" margins="{top=10}"/>
            </layout>
        </layout>
    </layout>

    <script><![CDATA[
        local inicializado = false;

        local function logFCEXT(msg)
            pcall(function()
                local logPath = nil;
                pcall(function()
                    local ad = os.getenv("LOCALAPPDATA");
                    if ad then logPath = ad .. "\\Firecast\\fcext_ficha_log.txt"; end;
                end);
                if not logPath then
                    -- Fallback: try using fcext if available
                    pcall(function()
                        local ok, fc = pcall(require, "fcext");
                        if ok and fc and fc.log then fc.log(tostring(msg)); end;
                    end);
                    return;
                end;
                local f = io.open(logPath, "a");
                if f then
                    f:write(os.date("[%H:%M:%S] ") .. tostring(msg) .. "\n");
                    f:close();
                end;
            end);
        end;

        local function carregarInterfaceAvancada()
            if inicializado then
                logFCEXT("carregarInterfaceAvancada: ja inicializado, ignorando");
                return;
            end;
            if sheet == nil then
                logFCEXT("carregarInterfaceAvancada: sheet == nil, abortando");
                return;
            end;
            
            logFCEXT("carregarInterfaceAvancada: Iniciando...");
            
            local ok, fcext = pcall(require, "fcext");
            if not ok or not fcext then
                logFCEXT("ERRO: require('fcext') falhou: " .. tostring(fcext));
                self.fallbackError.visible = true;
                return;
            end;
            logFCEXT("fcext carregado com sucesso");

            -- Discover path to fcext_ficha_nd.lua automatically
            local scriptName = "fcext_ficha_nd.lua";
            local code = nil;
            
            -- Build candidate paths using Windows userprofile pattern
            local candidates = {};
            
            -- Try getting LOCALAPPDATA via multiple methods
            local appdata = nil;
            pcall(function() appdata = os.getenv("LOCALAPPDATA"); end);
            
            if appdata then
                table.insert(candidates, appdata .. "\\Firecast\\" .. scriptName);
            end;
            
            -- Try common Windows paths using USERPROFILE
            local userprofile = nil;
            pcall(function() userprofile = os.getenv("USERPROFILE"); end);
            if userprofile then
                table.insert(candidates, userprofile .. "\\AppData\\Local\\Firecast\\" .. scriptName);
            end;
            
            -- Fallback: try to find via fcext.listDir on common drives
            -- The proxy DLL is in the same directory, so we can check relative
            local drives = {"C", "D"};
            for _, drive in ipairs(drives) do
                -- Try Users directories
                local usersDir = drive .. ":\\Users";
                local ok2, users = pcall(fcext.listDir, usersDir);
                if ok2 and users then
                    for _, user in ipairs(users) do
                        if user ~= "Public" and user ~= "Default" and user ~= "Default User" and user ~= "All Users" then
                            local tryPath = usersDir .. "\\" .. user .. "\\AppData\\Local\\Firecast\\" .. scriptName;
                            if fcext.fileExists(tryPath) then
                                table.insert(candidates, 1, tryPath); -- priority
                            end;
                        end;
                    end;
                end;
            end;
            
            -- Try each candidate
            for _, path in ipairs(candidates) do
                logFCEXT("Tentando: " .. path);
                if fcext.fileExists(path) then
                    code = fcext.readFile(path);
                    if code then
                        logFCEXT("Encontrado em: " .. path);
                        break;
                    end;
                end;
            end;
            
            if not code then
                logFCEXT("ERRO: fcext_ficha_nd.lua nao encontrado em nenhum caminho");
                self.fallbackError.visible = true;
                if self.lblErroDetalhe then self.lblErroDetalhe.text = "Detalhe: fcext_ficha_nd.lua nao encontrado na pasta do Firecast."; end;
                return;
            end;
            logFCEXT("fcext_ficha_nd.lua lido (" .. #code .. " bytes)");

            local factory, err = load(code);
            if not factory then
                logFCEXT("ERRO: Falha de compilacao: " .. tostring(err));
                self.fallbackError.visible = true;
                if self.lblErroDetalhe then self.lblErroDetalhe.text = "Detalhe: " .. tostring(err); end;
                return;
            end;
            logFCEXT("Codigo compilado com sucesso");

            local okExec, criarFicha = pcall(factory);
            if not okExec then
                logFCEXT("ERRO: factory() falhou: " .. tostring(criarFicha));
                self.fallbackError.visible = true;
                if self.lblErroDetalhe then self.lblErroDetalhe.text = "Detalhe: factory() erro: " .. tostring(criarFicha); end;
                return;
            end;
            logFCEXT("factory() retornou: " .. type(criarFicha));
            
            -- Pass the sheet (data) and the self.containerPrincipal (UI container)
            local okRun, result = pcall(criarFicha, sheet, self.containerPrincipal);
            if not okRun then
                logFCEXT("ERRO: criarFicha() falhou: " .. tostring(result));
                self.fallbackError.visible = true;
                if self.lblErroDetalhe then self.lblErroDetalhe.text = "Detalhe: " .. tostring(result); end;
                return;
            end;

            logFCEXT("criarFicha resultado: " .. tostring(result));

            if result ~= "OK" then
                self.fallbackError.visible = true;
                if self.lblErroDetalhe then self.lblErroDetalhe.text = "Detalhe: " .. tostring(result); end;
            else
                inicializado = true;
                logFCEXT("Ficha inicializada com SUCESSO!");
            end;
        end;
    ]]></script>

    <event name="onNodeReady">
        carregarInterfaceAvancada();
    </event>
</form>
